{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-configuration-receipt-v1.schema.json",
  "title": "Elegy Configuration Receipt V1",
  "description": "Machine-readable receipt and verification report for deterministic configuration materialization.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mode",
    "subjectKind",
    "subjectId",
    "sourceKind",
    "sourceRef",
    "targetRoot",
    "force",
    "summary",
    "verified"
  ],
  "properties": {
    "schemaVersion": { "const": "elegy-configuration-receipt/v1" },
    "mode": {
      "type": "string",
      "enum": ["apply", "dry-run", "verify"]
    },
    "subjectKind": {
      "type": "string",
      "enum": ["template", "profile"]
    },
    "subjectId": {
      "type": "string",
      "minLength": 1
    },
    "sourceKind": {
      "type": "string",
      "enum": ["builtin", "file", "package"]
    },
    "sourceRef": {
      "type": "string",
      "minLength": 1
    },
    "targetRoot": {
      "type": "string",
      "minLength": 1
    },
    "force": {
      "type": "boolean"
    },
    "bindings": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/receiptEntry" }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "verified": {
      "type": "boolean"
    }
  },
  "$defs": {
    "assetFamily": {
      "type": "string",
      "enum": ["instruction", "skill", "agent", "mcp", "hook", "support-file"]
    },
    "action": {
      "type": "string",
      "enum": ["created", "updated", "would-create", "would-update", "skipped", "verified", "mismatched", "conflict"]
    },
    "receiptEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["templateId", "operationId", "family", "action", "path"],
      "properties": {
        "templateId": {
          "type": "string",
          "minLength": 1
        },
        "operationId": {
          "type": "string",
          "minLength": 1
        },
        "family": { "$ref": "#/$defs/assetFamily" },
        "action": { "$ref": "#/$defs/action" },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "expectedHash": {
          "type": "string",
          "minLength": 1
        },
        "actualHash": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created", "updated", "skipped", "verified", "mismatched", "conflicts", "issues"],
      "properties": {
        "created": { "type": "integer", "minimum": 0 },
        "updated": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "verified": { "type": "integer", "minimum": 0 },
        "mismatched": { "type": "integer", "minimum": 0 },
        "conflicts": { "type": "integer", "minimum": 0 },
        "issues": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
