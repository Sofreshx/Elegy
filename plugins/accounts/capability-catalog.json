{
  "schemaVersion": "elegy-capability-catalog/v1",
  "plugin": "elegy-accounts",
  "pluginVersion": "0.1.0",
  "capabilities": [
    {
      "id": "accounts.mcp",
      "kind": "mcp",
      "sideEffectClass": "mutation",
      "contractVersion": "v1",
      "description": "Discover generic provider packs and request, inspect, present, resume, or revoke credential-backed account access without revealing credentials.",
      "invocation": {
        "executable": "elegy-accounts",
        "command": ["mcp"],
        "toolName": "account_list"
      }
    },
    {
      "id": "accounts.center",
      "kind": "cli",
      "sideEffectClass": "mutation",
      "contractVersion": "v1",
      "description": "Open the local human authorization and account-management surface.",
      "invocation": {
        "executable": "elegy-accounts",
        "command": ["open"]
      }
    },
    {
      "id": "accounts.actions.mcp",
      "kind": "mcp",
      "sideEffectClass": "query",
      "contractVersion": "v1",
      "description": "Perform trusted typed GitHub and Cloudflare reads through the local broker without exposing credentials or leases.",
      "invocation": {
        "executable": "elegy-accounts",
        "command": ["actions-mcp"],
        "toolName": "github_profile_read"
      }
    }
  ]
}
