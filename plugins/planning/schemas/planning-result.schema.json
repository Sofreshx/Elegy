{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/planning-result.schema.json",
  "title": "PlanningResult",
  "description": "Machine-mode planning CLI envelope with typed data payloads for durable planning entities and operations.",
  "type": "object",
  "required": ["schemaVersion", "command", "status"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "planning-result/v1"
    },
    "correlationId": {
      "type": ["string", "null"]
    },
    "nonInteractive": {
      "type": "boolean"
    },
    "command": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["ok", "invalid", "error"]
    },
    "data": {
      "oneOf": [
        { "type": "object", "required": ["record", "validation"] },
        { "type": "object", "required": ["goal", "validation"] },
        { "type": "object", "required": ["roadmap", "validation"] },
        { "type": "object", "required": ["workPoint", "validation"] },
        { "type": "object", "required": ["plan", "validation"] },
        { "type": "object", "required": ["issue", "validation"] },
        { "type": "object", "required": ["status", "findings"] },
        { "type": "object", "required": ["dbPath", "schemaVersion"] },
        { "type": "object", "required": ["events"] },
        { "type": "object", "required": ["goals"] },
        { "type": "object", "required": ["roadmaps"] },
        { "type": "object", "required": ["workPoints"] },
        { "type": "object", "required": ["plans"] },
        { "type": "object", "required": ["todos"] },
        { "type": "object", "required": ["issues"] },
        { "type": "object", "required": ["scopes"] },
        { "type": "object", "required": ["scope"] },
        { "type": "object", "required": ["entityType", "entityId", "format", "outputPath"] },
        { "type": "object", "required": ["insights"] },
        { "type": "object", "required": ["sessions"] },
        { "type": "object", "required": ["activeProjectRun"] },
        { "type": "object", "required": ["results"] },
        { "type": "object", "required": ["tags"] },
        { "type": "object", "required": ["worktrees"] },
        { "type": "object", "required": ["nodes"] },
        { "type": "object", "required": ["edges"] },
        { "type": "object", "required": ["acceptance"] },
        { "type": "object", "required": ["evidence"] },
        { "type": "object", "required": ["candidates", "blocked"] },
        { "type": "object", "required": ["transitioned", "rejected", "totalMatched", "totalTransitioned"] },
        { "type": "object", "required": ["createdNodes", "revisedNodes", "unchangedNodes", "createdEdges", "revisedEdges", "unchangedEdges", "conflicts", "validation"] },
        { "type": "object", "required": ["addedNodes", "removedNodes", "changedNodes", "unchangedNodes", "addedEdges", "removedEdges", "changedEdges", "unchangedEdges"] },
        { "type": "object", "required": ["discoveries"] },
        { "type": "object", "required": ["discovery"] },
        { "type": "object", "required": ["relationships"] },
        { "type": "object", "required": ["checkpoints"] },
        { "type": "object", "required": ["templates"] },
        { "type": "object", "required": ["output"] },
        { "type": "object", "required": ["capabilities", "cliVersion", "resultSchemaVersion", "planningSchemaVersion"] },
        { "type": "object", "required": ["schemaVersion", "plugin", "pluginVersion", "capabilities"] },
        { "type": "object", "required": ["plugin", "pluginVersion", "cliVersion", "resultSchemaVersion", "planningSchemaVersion", "capabilityDigest"] },
        { "type": "object", "required": ["workflowView"] },
        { "type": "object", "required": ["bundle"] },
        { "type": "object", "required": ["workflowPrepare"] },
        { "type": "object", "required": ["workflowResult"] },
        { "type": "object", "required": ["workflowArtifactImport"] },
        { "type": "object", "required": ["workflowArtifactExport"] },
        {
          "type": "object",
          "required": [
            "created",
            "updated",
            "unchanged",
            "skipped",
            "rejected",
            "validationFindings",
            "nextRunnableWorkPoints"
          ]
        }
      ]
    },
    "error": {
      "type": ["string", "null"]
    },
    "warnings": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
