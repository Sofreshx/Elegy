{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/piloting-policy-decision.schema.json",
  "title": "PilotingPolicyDecision",
  "description": "Typed allow, deny, simulate, or escalate decision for a targeted piloting action in the contracts-first phase.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "decisionId",
    "actionId",
    "targetId",
    "decision",
    "sideEffectClass",
    "evaluatedAtUtc",
    "reasons"
  ],
  "properties": {
    "schemaVersion": {
      "const": "elegy-piloting-policy-decision/v1"
    },
    "decisionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "actionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "targetId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "deny", "simulate", "escalate"]
    },
    "sideEffectClass": {
      "type": "string",
      "enum": ["none", "read_only", "disk_read", "disk_write", "network_outbound", "process_spawn", "desktop_ui"]
    },
    "evaluatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "policyRef": {
      "type": "string",
      "minLength": 1
    },
    "approvalRequirement": {
      "type": "string",
      "enum": ["none", "advisory", "explicit"]
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidenceRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": { "const": "escalate" }
        }
      },
      "then": {
        "required": ["approvalRequirement"]
      }
    }
  ]
}
