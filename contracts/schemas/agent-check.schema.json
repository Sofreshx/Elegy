{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/agent-check.schema.json",
  "title": "Elegy Agent Check Payload",
  "description": "Data payload emitted by `elegy agent check --json` for host profile validation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["valid", "integrationVersion", "profile", "selected"],
  "properties": {
    "valid": { "type": "boolean" },
    "integrationVersion": { "type": "string", "const": "elegy.agent/v1" },
    "profile": { "$ref": "#/$defs/profileSummary" },
    "selected": { "$ref": "#/$defs/selectedSummary" }
  },
  "$defs": {
    "profileSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profileProvided",
        "profilePath",
        "profileId",
        "schemaVersion",
        "alwaysIncludeRouter",
        "routerAvailable",
        "selectedSkillCount",
        "selectedCapabilityCount",
        "totalSkillCount",
        "totalCapabilityCount"
      ],
      "properties": {
        "profileProvided": { "type": "boolean" },
        "profilePath": { "type": ["string", "null"] },
        "profileId": { "type": ["string", "null"] },
        "schemaVersion": { "type": ["string", "null"] },
        "alwaysIncludeRouter": { "type": "boolean" },
        "routerAvailable": { "type": "boolean" },
        "selectedSkillCount": { "type": "integer", "minimum": 0 },
        "selectedCapabilityCount": { "type": "integer", "minimum": 0 },
        "totalSkillCount": { "type": "integer", "minimum": 0 },
        "totalCapabilityCount": { "type": "integer", "minimum": 0 }
      }
    },
    "selectedSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skills", "capabilities"],
      "properties": {
        "skills": {
          "type": "array",
          "items": { "$ref": "#/$defs/selectedSkill" }
        },
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/selectedCapability" }
        }
      }
    },
    "selectedSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "category", "capabilitiesCount", "lifecycleState"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "capabilitiesCount": { "type": "integer", "minimum": 0 },
        "lifecycleState": { "type": "string", "minLength": 1 }
      }
    },
    "selectedCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "skillId", "name", "hasSideEffects"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "skillId": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "hasSideEffects": { "type": "boolean" }
      }
    }
  }
}