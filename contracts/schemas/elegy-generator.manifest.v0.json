{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-generator.manifest.v0.json",
  "title": "Elegy Generator Manifest v0",
  "description": "Dry-run foundation manifest for a generator-capable or solved-unit-like contract.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "kind", "version", "extensions"],
  "properties": {
    "schemaVersion": {
      "const": "elegy-generator.manifest/v0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": true
    },
    "intent": {
      "type": "object",
      "additionalProperties": true
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "preconditions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "emits": {
      "type": "object",
      "additionalProperties": true
    },
    "validation": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "config": {}
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
