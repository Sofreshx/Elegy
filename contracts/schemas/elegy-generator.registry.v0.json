{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-generator.registry.v0.json",
  "title": "Elegy Generator Registry v0",
  "description": "Optional explicit registry of generator-family contracts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "kind", "version", "entries", "extensions"],
  "properties": {
    "schemaVersion": {
      "const": "elegy-generator.registry/v0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "const": "registry"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": true
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "schemaVersion": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 }
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
