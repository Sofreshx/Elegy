{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/piloting-readiness-report.schema.json",
  "title": "PilotingReadinessReport",
  "description": "Dependencies, target availability, blocked reasons, and drift status for a targeted piloting adapter.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reportId",
    "targetId",
    "generatedAtUtc",
    "availability",
    "dependencies",
    "blockedReasons",
    "driftStatus"
  ],
  "properties": {
    "schemaVersion": {
      "const": "elegy-piloting-readiness-report/v1"
    },
    "reportId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "targetId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "availability": {
      "type": "string",
      "enum": ["available", "unavailable", "degraded"]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["ready", "missing", "unsupported", "degraded"]
          },
          "details": { "type": "string", "minLength": 1 }
        }
      }
    },
    "blockedReasons": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "driftStatus": {
      "type": "string",
      "enum": ["aligned", "drifted", "unknown"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "availability": { "const": "available" } },
        "required": ["availability"]
      },
      "then": {
        "properties": {
          "blockedReasons": { "maxItems": 0 }
        }
      }
    }
  ]
}
