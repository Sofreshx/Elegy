{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-generator.contract-meta.v0.json",
  "title": "Elegy Generator Contract Meta v0",
  "description": "Shared identity and extension shape for the elegy-generator contract family.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "kind", "version", "extensions"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^elegy-generator\\.[a-z-]+/v0$"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
