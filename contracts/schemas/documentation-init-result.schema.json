{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/documentation-init-result.schema.json",
  "title": "DocumentationInitResult",
  "description": "Machine-mode result envelope for elegy-documentation init.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "command", "status"],
  "properties": {
    "schemaVersion": {
      "const": "documentation-init-result/v1"
    },
    "correlationId": {
      "type": ["string", "null"]
    },
    "nonInteractive": {
      "type": "boolean"
    },
    "command": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["ok", "invalid", "error"]
    },
    "data": {
      "$ref": "#/$defs/initData"
    },
    "error": {
      "type": ["string", "null"]
    }
  },
  "$defs": {
    "repoRelativePath": {
      "type": "string",
      "minLength": 1
    },
    "authorityRoots": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "planning", "research", "generated"],
      "properties": {
        "current": {
          "type": "array",
          "items": { "type": "string" }
        },
        "planning": {
          "type": "array",
          "items": { "type": "string" }
        },
        "research": {
          "type": "array",
          "items": { "type": "string" }
        },
        "generated": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "derivedSurfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sidebars", "manifests", "llms", "bundles"],
      "properties": {
        "sidebars": {
          "type": "array",
          "items": { "type": "string" }
        },
        "manifests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "llms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bundles": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "freshnessWarnings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currentDays", "planningDays", "researchDays"],
      "properties": {
        "currentDays": { "type": "integer", "minimum": 0 },
        "planningDays": { "type": "integer", "minimum": 0 },
        "researchDays": { "type": "integer", "minimum": 0 }
      }
    },
    "configView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "compatibilityMode",
        "authorityRoots",
        "entrypoints",
        "derivedSurfaces",
        "requiredFrontmatter",
        "freshnessWarnings",
        "localExceptions"
      ],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "enum": ["elegy-docs/v1", "elegy-documentation/v2"]
        },
        "compatibilityMode": {
          "type": "string",
          "enum": ["v1-compat", "v2"]
        },
        "authorityRoots": {
          "$ref": "#/$defs/authorityRoots"
        },
        "entrypoints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "derivedSurfaces": {
          "$ref": "#/$defs/derivedSurfaces"
        },
        "requiredFrontmatter": {
          "type": "array",
          "items": { "type": "string" }
        },
        "freshnessWarnings": {
          "$ref": "#/$defs/freshnessWarnings"
        },
        "localExceptions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "initData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectRoot",
        "configFound",
        "configPath",
        "dryRun",
        "config",
        "created",
        "skipped"
      ],
      "properties": {
        "projectRoot": { "type": "string", "minLength": 1 },
        "configFound": { "type": "boolean" },
        "configPath": { "$ref": "#/$defs/repoRelativePath" },
        "dryRun": { "type": "boolean" },
        "config": { "$ref": "#/$defs/configView" },
        "created": {
          "type": "array",
          "items": { "$ref": "#/$defs/repoRelativePath" }
        },
        "skipped": {
          "type": "array",
          "items": { "$ref": "#/$defs/repoRelativePath" }
        }
      }
    }
  }
}
