{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-plugin-package.schema.json",
  "title": "Elegy Plugin Package",
  "description": "Portable package metadata for bundling Elegy skill definitions, instruction skills, capability projections, MCP projection metadata, configuration templates/profiles, docs, tool requirements, and neutral publishing/provenance metadata for host-governed import.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "identity", "components"],
  "properties": {
    "schemaVersion": { "const": "elegy-plugin-package/v1" },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageId", "name", "version"],
      "properties": {
        "packageId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "description": "Descriptive tags for discovery (e.g. ['planning', 'roadmap']). Free-form.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "documentationUri": {
          "type": "string",
          "format": "uri"
        },
        "subsetOf": {
          "type": "array",
          "description": "Capability IDs that the package deliberately omits from its capabilityProjections[]. When declared, every capability in the referenced skill's capabilities[] must either appear in components.capabilityProjections[] or be listed here.",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skillDefinitions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/skillDefinitionComponent" }
        },
        "instructionSkills": {
          "type": "array",
          "items": { "$ref": "#/$defs/pathComponent" }
        },
        "capabilityProjections": {
          "type": "array",
          "items": { "$ref": "#/$defs/capabilityProjectionComponent" }
        },
        "docs": {
          "type": "array",
          "items": { "$ref": "#/$defs/pathComponent" }
        },
        "configurationTemplates": {
          "type": "array",
          "items": { "$ref": "#/$defs/configurationComponent" }
        },
        "configurationProfiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/configurationComponent" }
        },
        "toolRequirements": {
          "type": "array",
          "description": "Required CLI tools and MCP surfaces this package needs installed and probeable.",
          "items": { "$ref": "#/$defs/toolRequirementComponent" }
        }
      }
    },
    "hostPolicyHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sideEffectClass": { "$ref": "#/$defs/sideEffectClass" },
        "requiresApproval": {
          "type": "boolean"
        },
        "policyTags": {
          "type": "array",
          "description": "Policy routing tags consumed by host policy. Distinct from descriptive metadata.tags.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "publishing": {
      "$ref": "#/$defs/publishingMetadata"
    },
    "elegyCompatibility": {
      "$ref": "#/$defs/elegyCompatibility"
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?!.*(?:^|[/\\\\])(?:[/\\\\]|$)).+$"
    },
    "sideEffectClass": {
      "type": "string",
      "enum": ["none", "read_only", "disk_read", "disk_write", "network_outbound", "process_spawn", "desktop_ui"]
    },
    "pathComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]+$"
        },
        "path": { "$ref": "#/$defs/relativePath" },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "skillDefinitionComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "definitionRef": { "$ref": "#/$defs/relativePath" },
        "definition": { "$ref": "skill.schema.json" }
      },
      "anyOf": [
        { "required": ["definitionRef"] },
        { "required": ["definition"] }
      ]
    },
    "capabilityProjectionComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "skill", "capability", "lane", "supportsDryRun"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]+$"
        },
        "skill": {
          "type": "string",
          "minLength": 1
        },
        "capability": {
          "type": "string",
          "minLength": 1
        },
        "lane": {
          "type": "string",
          "enum": ["api", "mcp", "plugin", "cli", "subprocess", "rust"]
        },
        "supportsDryRun": {
          "type": "boolean"
        },
        "inputSchema": {
          "type": "object"
        },
        "outputSchema": {
          "type": "object"
        },
        "sideEffectClass": { "$ref": "#/$defs/sideEffectClass" },
        "projection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "projections": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["function_calling", "mcp", "cli"]
              },
              "uniqueItems": true
            },
            "functionName": {
              "type": "string",
              "minLength": 1
            },
            "mcpToolName": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "capabilityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skill", "capability"],
      "properties": {
        "skill": {
          "type": "string",
          "minLength": 1
        },
        "capability": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "configurationComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]+$"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "toolRequirementComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toolName", "cliBinary"],
      "properties": {
        "toolName": {
          "type": "string",
          "minLength": 1,
          "description": "Stable tool name for this requirement (e.g. 'elegy-planning')."
        },
        "cliBinary": {
          "type": "string",
          "minLength": 1,
          "description": "CLI binary name to resolve and probe (e.g. 'elegy-planning')."
        },
        "minVersion": {
          "type": "string",
          "description": "Optional minimum version string."
        },
        "probeCommand": {
          "type": "string",
          "description": "Optional override for the probe command (defaults to '--version')."
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "compatibilityMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "versionRange"],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "versionRange": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "publishingMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cratePath": {
          "type": "string",
          "minLength": 1,
          "description": "Workspace-relative path to the Rust crate that produces this surface's binary (e.g. 'elegy-memory'). The central publish orchestrator passes this to `cargo build -p`. Required when the surface produces a binary; may be absent for skill-only surfaces that ship without a Rust build (e.g. external-CLI shim bridges). The orchestrator falls back to the `identity.name` field when cratePath is absent and a binary is expected."
        },
        "assetKind": {
          "type": "string",
          "enum": ["cli", "wrapper"],
          "description": "Whether this surface produces CLI archives (binary only) or wrapper archives (binary + SKILL.md bridge + installer). Drives the staging contents in the reusable publish workflow. Required when the surface has a `publishing` block."
        },
        "marketplaceTarget": {
          "type": "string",
          "minLength": 1
        },
        "importMode": {
          "type": "string",
          "enum": ["package", "dry_run"]
        },
        "sourceRepository": {
          "type": "string",
          "format": "uri"
        },
        "sourceRef": {
          "type": "string",
          "minLength": 1
        },
        "sourceCommit": {
          "type": "string",
          "minLength": 1
        },
        "changelogRef": {
          "$ref": "#/$defs/relativePath"
        },
        "provenanceRef": {
          "$ref": "#/$defs/relativePath"
        },
        "signatureRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relativePath"
          },
          "uniqueItems": true
        },
        "compatibility": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/compatibilityMetadata"
          }
        },
        "archiveFamily": {
          "type": "string",
          "minLength": 1,
          "description": "Per-feature archive asset family name used to derive release asset names. The reusable publish workflow turns this into <archiveFamily>-<version>-<target>.zip for binaries, or <archiveFamily>-<bundleVersion>.zip for wrappers. Owns the asset name; the central publish workflow does not enumerate it."
        },
        "assetPrefix": {
          "type": "string",
          "minLength": 1,
          "description": "Per-feature asset prefix used inside the wrapper archive layout (typically the same as archiveFamily for wrappers, or the binary name for CLI archives). The generic installer reads this to know which asset name to expect in the release."
        },
        "skillBridge": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path (within the feature tree) of the SKILL.md mirror that wrapper archives bundle. Optional; absent for non-wrapper features."
        },
        "installer": {
          "type": "string",
          "minLength": 1,
          "description": "Filename of the wrapper's installer script inside the archive (e.g. 'install.sh'). Optional; absent for non-wrapper features."
        },
        "prePublishHook": {
          "type": "string",
          "minLength": 1,
          "description": "Optional shell command the per-feature publish workflow runs before cargo build. Use sparingly; the per-feature workflow already covers the standard cases."
        },
        "postPublishHook": {
          "type": "string",
          "minLength": 1,
          "description": "Optional shell command the per-feature publish workflow runs after the asset is uploaded. Use sparingly."
        },
        "targets": {
          "type": "array",
          "description": "Optional override of the default target list (x86_64-pc-windows-msvc, x86_64-unknown-linux-gnu, aarch64-apple-darwin). Use when a feature cannot build for a standard target.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "elegyCompatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractBundleVersion", "schemaLine"],
      "properties": {
        "contractBundleVersion": {
          "type": "string",
          "minLength": 1
        },
        "schemaLine": {
          "type": "string",
          "minLength": 1
        },
        "minimumElegyToolingVersion": {
          "type": "string",
          "minLength": 1
        },
        "contractsSource": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "extensions": {
      "type": "object",
      "description": "Optional free-form extension surface for host-specific or experimental metadata. Preserved on round-trip; not semantically validated by the contract.",
      "additionalProperties": { "type": ["string", "number", "boolean", "array", "object"] }
    }
  }
}
