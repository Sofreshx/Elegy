{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/documentation-check-result.schema.json",
  "title": "DocumentationCheckResult",
  "description": "Machine-mode result envelope for elegy-documentation check.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "command", "status"],
  "properties": {
    "schemaVersion": {
      "const": "documentation-check-result/v1"
    },
    "correlationId": {
      "type": ["string", "null"]
    },
    "nonInteractive": {
      "type": "boolean"
    },
    "command": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["ok", "invalid", "error"]
    },
    "data": {
      "$ref": "#/$defs/checkData"
    },
    "error": {
      "type": ["string", "null"]
    }
  },
  "$defs": {
    "authorityClass": {
      "type": "string",
      "enum": ["current", "planning", "research", "generated", "other"]
    },
    "sourceOfTruth": {
      "type": "string",
      "enum": [
        "current-canon",
        "planning-non-canon",
        "research-non-canon",
        "generated-derived",
        "unclassified"
      ]
    },
    "freshnessValue": {
      "type": "string",
      "enum": ["fresh", "warning", "unknown", "n/a"]
    },
    "driftStatus": {
      "type": "string",
      "enum": ["current", "drifted", "unreadable", "present", "missing"]
    },
    "surfaceKind": {
      "type": "string",
      "enum": ["sidebar", "manifest", "llms", "bundle"]
    },
    "issueSeverity": {
      "type": "string",
      "enum": ["error", "warning"]
    },
    "authorityRoots": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "planning", "research", "generated"],
      "properties": {
        "current": { "type": "array", "items": { "type": "string" } },
        "planning": { "type": "array", "items": { "type": "string" } },
        "research": { "type": "array", "items": { "type": "string" } },
        "generated": { "type": "array", "items": { "type": "string" } }
      }
    },
    "derivedSurfacesConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sidebars", "manifests", "llms", "bundles"],
      "properties": {
        "sidebars": { "type": "array", "items": { "type": "string" } },
        "manifests": { "type": "array", "items": { "type": "string" } },
        "llms": { "type": "array", "items": { "type": "string" } },
        "bundles": { "type": "array", "items": { "type": "string" } }
      }
    },
    "freshnessWarnings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currentDays", "planningDays", "researchDays"],
      "properties": {
        "currentDays": { "type": "integer", "minimum": 0 },
        "planningDays": { "type": "integer", "minimum": 0 },
        "researchDays": { "type": "integer", "minimum": 0 }
      }
    },
    "configView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "compatibilityMode",
        "authorityRoots",
        "entrypoints",
        "derivedSurfaces",
        "requiredFrontmatter",
        "freshnessWarnings",
        "localExceptions"
      ],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "enum": ["elegy-docs/v1", "elegy-documentation/v2"]
        },
        "compatibilityMode": {
          "type": "string",
          "enum": ["v1-compat", "v2"]
        },
        "authorityRoots": { "$ref": "#/$defs/authorityRoots" },
        "entrypoints": { "type": "array", "items": { "type": "string" } },
        "derivedSurfaces": { "$ref": "#/$defs/derivedSurfacesConfig" },
        "requiredFrontmatter": { "type": "array", "items": { "type": "string" } },
        "freshnessWarnings": { "$ref": "#/$defs/freshnessWarnings" },
        "localExceptions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "authorityClass",
        "sourceOfTruth",
        "title",
        "freshness"
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "authorityClass": { "$ref": "#/$defs/authorityClass" },
        "sourceOfTruth": { "$ref": "#/$defs/sourceOfTruth" },
        "title": { "type": "string", "minLength": 1 },
        "status": { "type": ["string", "null"] },
        "docKind": { "type": ["string", "null"] },
        "summary": { "type": ["string", "null"] },
        "created": { "type": ["string", "null"] },
        "updated": { "type": ["string", "null"] },
        "schemaVersion": { "type": ["string", "null"] },
        "freshness": { "$ref": "#/$defs/freshnessValue" }
      }
    },
    "derivedSurfaceState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "surfaceKind", "exists", "driftStatus"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "surfaceKind": { "$ref": "#/$defs/surfaceKind" },
        "exists": { "type": "boolean" },
        "driftStatus": { "$ref": "#/$defs/driftStatus" }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "path", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/issueSeverity" },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "checkData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "projectRoot",
        "configFound",
        "configPath",
        "config",
        "valid",
        "filesChecked",
        "documentCount",
        "documents",
        "derivedSurfaces",
        "issues"
      ],
      "properties": {
        "schemaVersion": {
          "const": "documentation-check-result/v1"
        },
        "projectRoot": { "type": "string", "minLength": 1 },
        "configFound": { "type": "boolean" },
        "configPath": { "type": "string", "minLength": 1 },
        "config": { "$ref": "#/$defs/configView" },
        "valid": { "type": "boolean" },
        "filesChecked": { "type": "integer", "minimum": 0 },
        "documentCount": { "type": "integer", "minimum": 0 },
        "documents": {
          "type": "array",
          "items": { "$ref": "#/$defs/document" }
        },
        "derivedSurfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/derivedSurfaceState" }
        },
        "issues": {
          "type": "array",
          "items": { "$ref": "#/$defs/issue" }
        }
      }
    }
  }
}
