{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/piloting-adapter-manifest.schema.json",
  "title": "PilotingAdapterManifest",
  "description": "Contracts-first targeted piloting adapter metadata with supported software, surfaces, fixtures, and permissions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "adapterId",
    "displayName",
    "version",
    "mode",
    "supportedSoftware",
    "supportedSurfaces",
    "contracts",
    "fixtures",
    "permissions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "elegy-piloting-adapter-manifest/v1"
    },
    "adapterId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "const": "contracts_only"
    },
    "supportedSoftware": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "piloting-target-descriptor.schema.json" }
    },
    "supportedSurfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "piloting-surface-descriptor.schema.json" }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetDescriptorSchemaRef",
        "surfaceDescriptorSchemaRef",
        "observationFrameSchemaRef",
        "actionIntentSchemaRef",
        "actionResultSchemaRef",
        "readinessReportSchemaRef",
        "fixturePackSchemaRef",
        "policyDecisionSchemaRef",
        "simulationResultSchemaRef",
        "replayCheckpointSchemaRef",
        "lifecycleEventSchemaRef"
      ],
      "properties": {
        "targetDescriptorSchemaRef": { "type": "string", "minLength": 1 },
        "surfaceDescriptorSchemaRef": { "type": "string", "minLength": 1 },
        "observationFrameSchemaRef": { "type": "string", "minLength": 1 },
        "actionIntentSchemaRef": { "type": "string", "minLength": 1 },
        "actionResultSchemaRef": { "type": "string", "minLength": 1 },
        "readinessReportSchemaRef": { "type": "string", "minLength": 1 },
        "fixturePackSchemaRef": { "type": "string", "minLength": 1 },
        "policyDecisionSchemaRef": { "type": "string", "minLength": 1 },
        "simulationResultSchemaRef": { "type": "string", "minLength": 1 },
        "replayCheckpointSchemaRef": { "type": "string", "minLength": 1 },
        "lifecycleEventSchemaRef": { "type": "string", "minLength": 1 }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fixturePackId", "path"],
        "properties": {
          "fixturePackId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "path": {
            "$ref": "elegy-plugin-package-v1.schema.json#/$defs/relativePath"
          },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sideEffectClasses", "requiresHostApproval"],
      "properties": {
        "sideEffectClasses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["none", "read_only", "disk_read", "disk_write", "network_outbound", "process_spawn", "desktop_ui"]
          },
          "uniqueItems": true
        },
        "requiresHostApproval": {
          "type": "boolean"
        }
      }
    }
  }
}
