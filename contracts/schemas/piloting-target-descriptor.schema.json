{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/piloting-target-descriptor.schema.json",
  "title": "PilotingTargetDescriptor",
  "description": "Portable target identity, version, platform, and launch or attach hints for a targeted piloting adapter.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "targetId",
    "productName",
    "versionRange",
    "platforms",
    "launchHints",
    "attachHints"
  ],
  "properties": {
    "schemaVersion": {
      "const": "elegy-piloting-target-descriptor/v1"
    },
    "targetId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "productName": {
      "type": "string",
      "minLength": 1
    },
    "versionRange": {
      "type": "string",
      "minLength": 1
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["windows", "macos", "linux", "browser"]
      }
    },
    "launchHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executables": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "arguments": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "urls": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "required": ["executables", "arguments", "urls"]
    },
    "attachHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "processNames": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "windowTitles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "surfaceUrls": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "required": ["processNames", "windowTitles", "surfaceUrls"]
    }
  },
  "anyOf": [
    {
      "properties": {
        "launchHints": {
          "anyOf": [
            { "properties": { "executables": { "minItems": 1 } } },
            { "properties": { "urls": { "minItems": 1 } } }
          ]
        }
      }
    },
    {
      "properties": {
        "attachHints": {
          "anyOf": [
            { "properties": { "processNames": { "minItems": 1 } } },
            { "properties": { "windowTitles": { "minItems": 1 } } },
            { "properties": { "surfaceUrls": { "minItems": 1 } } }
          ]
        }
      }
    }
  ]
}
