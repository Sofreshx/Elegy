{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-plugin-readiness-v1.schema.json",
  "title": "Elegy Plugin Readiness Receipt V1",
  "description": "Verification and installation readiness result for an Elegy plugin package.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "packageIdentity", "readiness"],
  "properties": {
    "schemaVersion": { "const": "elegy-plugin-readiness/v1" },
    "packageIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageId", "name", "version"],
      "properties": {
        "packageId": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "readiness": {
      "type": "string",
      "enum": ["ready", "partial", "blocked"],
      "description": "Overall readiness: ready (all checks pass), partial (warnings/non-blocking issues), blocked (critical failures)."
    },
    "verifiedSkills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skillId", "status"],
        "properties": {
          "skillId": { "type": "string" },
          "status": { "type": "string", "enum": ["valid", "missing_ref", "invalid", "unresolved"] }
        }
      }
    },
    "projectedTools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["toolName", "functionName"],
        "properties": {
          "toolName": { "type": "string" },
          "functionName": { "type": "string" },
          "capabilityId": { "type": "string" },
          "lane": { "type": "string" }
        }
      }
    },
    "toolStatuses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["toolName", "status"],
        "properties": {
          "toolName": { "type": "string" },
          "cliBinary": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["present", "missing", "broken", "unprobed", "unknown"]
          },
          "probeOutput": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    },
    "omittedCapabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Capability IDs from referenced skills that are not projected in this package."
    },
    "unsupportedCapabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Capability IDs referenced by the package that don't exist in any referenced skill."
    },
    "sideEffectSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "none": { "type": "integer", "minimum": 0 },
        "read_only": { "type": "integer", "minimum": 0 },
        "disk_read": { "type": "integer", "minimum": 0 },
        "disk_write": { "type": "integer", "minimum": 0 },
        "network_outbound": { "type": "integer", "minimum": 0 },
        "process_spawn": { "type": "integer", "minimum": 0 },
        "desktop_ui": { "type": "integer", "minimum": 0 }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string", "description": "Stable finding code (e.g. 'PKG-REF-MISSING', 'CAP-PHANTOM', 'SIDE-LOOSEN', 'BIN-MISSING', 'BIN-BROKEN')." },
          "severity": { "type": "string", "enum": ["error", "warning", "info"] },
          "message": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    }
  }
}
