{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-documentation-v2.schema.json",
  "title": "Elegy Documentation Config V2",
  "description": "Repo-local documentation authority and validation configuration for the dedicated elegy-documentation surface.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "authorityRoots",
    "entrypoints",
    "derivedSurfaces",
    "requiredFrontmatter",
    "freshnessWarnings"
  ],
  "properties": {
    "schemaVersion": {
      "const": "elegy-documentation/v2"
    },
    "authorityRoots": {
      "$ref": "#/$defs/authorityRoots"
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repoRelativePath"
      }
    },
    "derivedSurfaces": {
      "$ref": "#/$defs/derivedSurfaces"
    },
    "requiredFrontmatter": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "title",
          "summary",
          "status",
          "doc_kind",
          "schema_version",
          "created",
          "updated",
          "owner"
        ]
      },
      "uniqueItems": true
    },
    "freshnessWarnings": {
      "$ref": "#/$defs/freshnessWarnings"
    },
    "localExceptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repoRelativePath"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "repoRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|[\\/])\\.\\.(?:[\\/]|$)).+"
    },
    "repoRelativeDirPath": {
      "allOf": [
        {
          "$ref": "#/$defs/repoRelativePath"
        },
        {
          "pattern": "^(?!.*\\.md$).+"
        }
      ]
    },
    "pathArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repoRelativePath"
      },
      "uniqueItems": true
    },
    "dirPathArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repoRelativeDirPath"
      },
      "uniqueItems": true
    },
    "authorityRoots": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "planning", "research", "generated"],
      "properties": {
        "current": {
          "$ref": "#/$defs/dirPathArray"
        },
        "planning": {
          "$ref": "#/$defs/dirPathArray"
        },
        "research": {
          "$ref": "#/$defs/dirPathArray"
        },
        "generated": {
          "$ref": "#/$defs/dirPathArray"
        }
      }
    },
    "derivedSurfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sidebars", "manifests", "llms", "bundles"],
      "properties": {
        "sidebars": {
          "$ref": "#/$defs/pathArray"
        },
        "manifests": {
          "$ref": "#/$defs/pathArray"
        },
        "llms": {
          "$ref": "#/$defs/pathArray"
        },
        "bundles": {
          "$ref": "#/$defs/pathArray"
        }
      }
    },
    "freshnessWarnings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currentDays", "planningDays", "researchDays"],
      "properties": {
        "currentDays": {
          "type": "integer",
          "minimum": 0
        },
        "planningDays": {
          "type": "integer",
          "minimum": 0
        },
        "researchDays": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
