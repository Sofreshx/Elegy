{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/2.0.0/skill-definition-v2.schema.json",
  "title": "SkillDefinitionV2",
  "description": "Unified skill definition contract (v2) combining governance, lifecycle, discovery, and per-capability implementation details for agent-consumable invocation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["skillFormat", "skillVersion", "identity", "capabilities", "lifecycleState"],
  "properties": {
    "skillFormat": {
      "type": "string",
      "const": "elegy-skill-definition"
    },
    "skillVersion": {
      "type": "integer",
      "const": 2
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "name", "version"],
      "properties": {
        "namespace": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "displayName": { "type": ["string", "null"] },
        "aliases": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "displayName": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] },
        "summary": { "type": ["string", "null"] },
        "category": { "type": ["string", "null"] },
        "author": { "type": ["string", "null"] },
        "license": { "type": ["string", "null"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "owners": { "type": "array", "items": { "type": "string" } },
        "documentationUri": { "type": ["string", "null"] }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "description", "implementation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "implementation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["executionType", "executableName", "arguments"],
            "properties": {
              "executionType": { "type": "string", "enum": ["subprocess", "library", "mcp"] },
              "executableName": { "type": "string", "minLength": 1 },
              "arguments": { "type": "array", "items": { "type": "string" } }
            }
          },
          "input": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "parameters": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "type", "required"],
                  "properties": {
                    "name": { "type": "string", "minLength": 1 },
                    "type": { "type": "string", "minLength": 1 },
                    "description": { "type": ["string", "null"] },
                    "required": { "type": "boolean" },
                    "default": {}
                  }
                }
              },
              "stdinFormat": { "type": ["string", "null"], "enum": ["json", "text", null] },
              "schemaRef": { "type": ["string", "null"] }
            }
          },
          "output": {
            "$comment": "Policy: every subprocess machine-invokable capability MUST declare output.schemaRef. Capabilities without it should be rejected or marked non-executable by validators. See skill-definition-v2.negative-no-output-schema.json for the negative test fixture.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "resultType": { "type": ["string", "null"] },
              "schemaRef": { "type": ["string", "null"] },
              "returnsCollection": { "type": "boolean" },
              "description": { "type": ["string", "null"] }
            }
          },
          "execution": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mode": { "type": "string", "enum": ["requestResponse", "longRunning", "streaming"] },
              "isDeterministic": { "type": "boolean" },
              "hasSideEffects": { "type": "boolean" },
              "timeoutSeconds": { "type": ["integer", "null"], "minimum": 1 }
            }
          },
          "composesWell": {
            "type": "object",
            "additionalProperties": false,
            "description": "Optional composition hints for agent chaining.",
            "properties": {
              "typicalNext": { "type": "array", "items": { "type": "string" } },
              "pipeableTo": { "type": "array", "items": { "type": "string" } },
              "outputConsumedBy": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["constraintId", "required"],
        "properties": {
          "constraintId": { "type": "string", "minLength": 1 },
          "description": { "type": ["string", "null"] },
          "required": { "type": "boolean" }
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "approvalRequirement": { "type": "string", "enum": ["none", "advisory", "required"] },
        "policyRefs": { "type": "array", "items": { "type": "string" } },
        "allowedContexts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keywords": { "type": "array", "items": { "type": "string" } },
        "triggers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pattern"],
            "properties": {
              "pattern": { "type": "string", "minLength": 1 },
              "description": { "type": ["string", "null"] }
            }
          }
        },
        "capabilityHints": { "type": "array", "items": { "type": "string" } },
        "isHidden": { "type": "boolean" }
      }
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "materializationKind": { "type": "string", "enum": ["declared", "dynamic"] },
        "sourceKind": { "type": "string", "enum": ["manual", "imported", "generated"] },
        "sourceRef": { "type": ["string", "null"] },
        "sourceVersion": { "type": ["string", "null"] }
      }
    },
    "lifecycleState": {
      "type": "string",
      "enum": ["draft", "active", "deprecated", "archived"]
    },
    "hostProjection": {
      "type": "object",
      "additionalProperties": false,
      "description": "Explicit host projection metadata for Holon and other runtime hosts. Defines how this skill's capabilities map to CLI, function-calling, and other host surfaces.",
      "properties": {
        "cliName": {
          "type": "string",
          "minLength": 1,
          "description": "Stable CLI binary name for subprocess invocation (e.g. 'elegy-planning', 'elegy-skills')."
        },
        "outputContractId": {
          "type": "string",
          "minLength": 1,
          "description": "Versioned output contract family identifier (e.g. 'elegy-planning-v1', 'elegy-skills-v1')."
        },
        "defaultSideEffectClass": {
          "type": "string",
          "enum": ["none", "read_only", "disk_read", "disk_write", "network_outbound", "process_spawn", "desktop_ui"],
          "description": "Default side-effect class for capabilities in this skill. Individual capabilities may override."
        },
        "capabilityProjections": {
          "type": "array",
          "description": "Per-capability function-calling projection metadata for host function-calling surfaces.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["capabilityId", "functionName"],
            "properties": {
              "capabilityId": {
                "type": "string",
                "minLength": 1,
                "description": "The governed capability id this projection derives from."
              },
              "functionName": {
                "type": "string",
                "minLength": 1,
                "description": "Stable function name for function-calling surfaces (e.g. 'planning_goal_create', 'skills_registry_search')."
              },
              "sideEffectClass": {
                "type": "string",
                "enum": ["none", "read_only", "disk_read", "disk_write", "network_outbound", "process_spawn", "desktop_ui"],
                "description": "Capability-specific side-effect class override."
              },
              "isDeterministic": {
                "type": "boolean",
                "description": "Whether this capability always produces the same output for the same input."
              }
            }
          }
        }
      }
    }
  }
}
