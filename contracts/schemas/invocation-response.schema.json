{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/invocation-response.schema.json",
  "title": "InvocationResponse",
  "description": "Capability-level invocation response envelope for governed execution outcomes outside agent-conversation-specific surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": ["requestId", "executionId", "status"],
  "properties": {
    "requestId": { "type": "string", "minLength": 1 },
    "executionId": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["completed", "failed", "cancelled"] },
    "output": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "failure": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["code", "message", "category", "retryable"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": [
            "invalidInput",
            "policy",
            "authentication",
            "authorization",
            "timeout",
            "dependency",
            "unavailable",
            "conflict",
            "internal",
            "unknown"
          ]
        },
        "retryable": { "type": "boolean" },
        "correlationId": { "type": ["string", "null"] },
        "details": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "cause": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "completedAt": { "type": ["string", "null"], "format": "date-time" },
    "traceRef": { "type": ["string", "null"] },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
