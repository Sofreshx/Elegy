{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/agent-request-envelope.schema.json",
  "title": "Agent Request Envelope",
  "description": "Canonical request envelope for provider-neutral agent execution and streaming flows.",
  "type": "object",
  "additionalProperties": false,
  "required": ["requestId", "messages", "context", "streamingRequested"],
  "properties": {
    "requestId": { "type": "string", "minLength": 1 },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content"],
        "properties": {
          "messageId": { "type": "string" },
          "role": { "type": "string", "enum": ["system", "user", "assistant", "tool"] },
          "content": { "type": "string", "minLength": 1 },
          "name": { "type": ["string", "null"] }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "correlationId": { "type": "string" },
        "sessionId": { "type": ["string", "null"] },
        "conversationId": { "type": ["string", "null"] },
        "requestedSkillId": { "type": ["string", "null"] },
        "capabilityHints": { "type": "array", "items": { "type": "string" } },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "streamingRequested": { "type": "boolean" }
  }
}