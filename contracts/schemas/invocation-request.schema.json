{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/invocation-request.schema.json",
  "title": "InvocationRequest",
  "description": "Capability-level invocation request envelope for governed execution outside agent-conversation-specific surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": ["requestId", "capabilityId", "input", "context"],
  "properties": {
    "requestId": { "type": "string", "minLength": 1 },
    "capabilityId": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["correlationId", "executionId", "requestedAt"],
      "properties": {
        "correlationId": { "type": "string", "minLength": 1 },
        "executionId": { "type": "string", "minLength": 1 },
        "requestedAt": { "type": "string", "format": "date-time" },
        "timeoutSeconds": { "type": ["integer", "null"], "minimum": 1 },
        "callerRef": { "type": ["string", "null"] },
        "policyContext": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "string" }
        },
        "traceRef": { "type": ["string", "null"] },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
