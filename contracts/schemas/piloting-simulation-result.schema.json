{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/piloting-simulation-result.schema.json",
  "title": "PilotingSimulationResult",
  "description": "Typed dry-run or simulation result for a targeted piloting action without live actuation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "simulationId",
    "actionId",
    "targetId",
    "status",
    "simulatedAtUtc",
    "predictedOutcome",
    "checks"
  ],
  "properties": {
    "schemaVersion": {
      "const": "elegy-piloting-simulation-result/v1"
    },
    "simulationId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "actionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "targetId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "status": {
      "type": "string",
      "enum": ["predicted", "blocked", "inconclusive"]
    },
    "simulatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "predictedOutcome": {
      "type": "object"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "policyDecisionRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "evidenceRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
