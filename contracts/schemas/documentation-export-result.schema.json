{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/documentation-export-result.schema.json",
  "title": "DocumentationExportResult",
  "description": "Machine-mode result envelope for elegy-documentation export commands.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "command", "status"],
  "properties": {
    "schemaVersion": {
      "const": "documentation-export-result/v1"
    },
    "correlationId": {
      "type": ["string", "null"]
    },
    "nonInteractive": {
      "type": "boolean"
    },
    "command": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["ok", "invalid", "error"]
    },
    "data": {
      "$ref": "#/$defs/exportData"
    },
    "error": {
      "type": ["string", "null"]
    }
  },
  "$defs": {
    "exportKind": {
      "type": "string",
      "enum": ["llms", "bundle"]
    },
    "exportData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "projectRoot",
        "configPath",
        "exportKind",
        "outputPath",
        "documentCount",
        "sourceCount",
        "generatedAt",
        "authorityPosture",
        "driftDetected"
      ],
      "properties": {
        "schemaVersion": {
          "const": "documentation-export-result/v1"
        },
        "projectRoot": { "type": "string", "minLength": 1 },
        "configPath": { "type": "string", "minLength": 1 },
        "exportKind": { "$ref": "#/$defs/exportKind" },
        "outputPath": { "type": "string", "minLength": 1 },
        "documentCount": { "type": "integer", "minimum": 0 },
        "sourceCount": { "type": "integer", "minimum": 0 },
        "generatedAt": { "type": "string", "format": "date-time" },
        "authorityPosture": {
          "type": "string",
          "const": "derived output; source files remain authoritative"
        },
        "driftDetected": { "type": "boolean" }
      }
    }
  }
}
