{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-plugin-package-v1.schema.json",
  "title": "Elegy Plugin Package V1",
  "description": "Portable package metadata for bundling Elegy skill definitions, instruction skills, MCP projection metadata, docs, and assets for host-governed import.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "identity", "components"],
  "properties": {
    "schemaVersion": { "const": "elegy-plugin-package/v1" },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageId", "name", "version"],
      "properties": {
        "packageId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "documentationUri": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skillDefinitions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/skillDefinitionComponent" }
        },
        "instructionSkills": {
          "type": "array",
          "items": { "$ref": "#/$defs/pathComponent" }
        },
        "mcpProjections": {
          "type": "array",
          "items": { "$ref": "#/$defs/mcpProjectionComponent" }
        },
        "capabilityProjections": {
          "type": "array",
          "items": { "$ref": "#/$defs/capabilityProjectionComponent" }
        },
        "docs": {
          "type": "array",
          "items": { "$ref": "#/$defs/pathComponent" }
        },
        "assets": {
          "type": "array",
          "items": { "$ref": "#/$defs/pathComponent" }
        }
      }
    },
    "hostPolicyHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sideEffectClass": { "$ref": "#/$defs/sideEffectClass" },
        "requiresApproval": {
          "type": "boolean"
        },
        "policyTags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?!.*(?:^|[/\\\\])(?:[/\\\\]|$)).+$"
    },
    "sideEffectClass": {
      "type": "string",
      "enum": ["none", "read_only", "disk_read", "disk_write", "network_outbound", "process_spawn", "desktop_ui"]
    },
    "pathComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": { "$ref": "#/$defs/relativePath" },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "skillDefinitionComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "definitionRef": { "$ref": "#/$defs/relativePath" },
        "definition": { "$ref": "skill-definition-v2.schema.json" }
      },
      "anyOf": [
        { "required": ["definitionRef"] },
        { "required": ["definition"] }
      ]
    },
    "mcpProjectionComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "descriptorRef": { "$ref": "#/$defs/relativePath" },
        "serverName": {
          "type": "string",
          "minLength": 1
        },
        "capabilityRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/capabilityRef" },
          "uniqueItems": true
        }
      },
      "anyOf": [
        { "required": ["descriptorRef"] },
        { "required": ["serverName"] }
      ]
    },
    "capabilityProjectionComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "skill", "capability", "lane", "supportsDryRun"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "skill": {
          "type": "string",
          "minLength": 1
        },
        "capability": {
          "type": "string",
          "minLength": 1
        },
        "lane": {
          "type": "string",
          "enum": ["api", "mcp", "plugin", "cli", "subprocess"]
        },
        "supportsDryRun": {
          "type": "boolean"
        },
        "inputSchema": {
          "type": "object"
        },
        "outputSchema": {
          "type": "object"
        },
        "sideEffectClass": { "$ref": "#/$defs/sideEffectClass" },
        "projection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "projections": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["function_calling", "mcp", "cli"]
              },
              "uniqueItems": true
            },
            "functionName": {
              "type": "string",
              "minLength": 1
            },
            "mcpToolName": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "capabilityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skill", "capability"],
      "properties": {
        "skill": {
          "type": "string",
          "minLength": 1
        },
        "capability": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
