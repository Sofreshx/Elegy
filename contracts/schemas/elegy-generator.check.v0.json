{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-generator.check.v0.json",
  "title": "Elegy Generator Check v0",
  "description": "Validation check declaration for the elegy-generator foundation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "kind", "version", "checkKind", "extensions"],
  "properties": {
    "schemaVersion": {
