{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-generator.receipt.v0.json",
  "title": "Elegy Generator Receipt v0",
  "description": "Evidence receipt for generator validation, checks, and dry-run planning.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "kind",
    "version",
    "operation",
    "status",
    "startedAt",
    "finishedAt",
    "runtime",
    "outputs",
    "checks",
    "warnings",
    "errors",
    "extensions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "elegy-generator.receipt/v0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "const": "receipt"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "manifestRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "operation": {
      "enum": ["validate", "check", "plan", "run"]
    },
    "status": {
      "enum": ["success", "warning", "failed", "unsupported"]
    },
    "startedAt": {
      "type": "string",
      "minLength": 1
    },
    "finishedAt": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "inputsHash": {
      "type": "string",
      "minLength": 1
    },
    "outputs": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "checks": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": true,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
