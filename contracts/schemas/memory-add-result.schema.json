{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/memory-add-result.schema.json",
  "title": "MemoryAddResult",
  "description": "Result of adding a memory including gate decision and the resulting memory record.",
  "type": "object",
  "additionalProperties": false,
  "required": ["action", "gateResult", "memory"],
  "properties": {
    "action": { "type": "string", "enum": ["added", "merged", "archived", "rejected"] },
    "gateResult": { "type": "string" },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "content", "scope", "memoryType", "provenance", "importanceScore", "reliabilityScore", "sensitivity", "state", "accessCount", "corroborationCount", "embeddingStale", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "content": { "type": "string" },
        "summary": { "type": ["string", "null"] },
        "scope": { "type": "string" },
        "memoryType": { "type": "string" },
        "provenance": { "type": "string" },
        "importanceScore": { "type": "number" },
        "reliabilityScore": { "type": "number" },
        "sensitivity": { "type": "string" },
        "state": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": ["string", "null"] },
        "customMetadata": { "type": "object" },
        "accessCount": { "type": "integer", "minimum": 0 },
        "corroborationCount": { "type": "integer", "minimum": 0 },
        "embeddingStale": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
