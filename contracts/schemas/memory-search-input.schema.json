{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/memory-search-input.schema.json",
  "title": "MemorySearchInput",
  "description": "Input schema for the memory-search capability.",
  "type": "object",
  "additionalProperties": false,
  "required": ["query"],
  "properties": {
    "query": { "type": "string", "minLength": 1 },
    "limit": { "type": "integer", "minimum": 1, "default": 20 },
    "includeDormant": { "type": "boolean", "default": false },
    "db": { "type": "string" },
    "scope": { "type": "string", "default": "workspace" },
    "provider": { "type": "string" }
  }
}
