{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/repo-branches.schema.json",
  "title": "RepoBranches",
  "description": "Structured read-only list of local branches, the current branch, and upstream tracking refs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["branches"],
  "properties": {
    "currentBranch": { "type": ["string", "null"] },
    "branches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "isCurrent"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "isCurrent": { "type": "boolean" },
          "upstream": { "type": ["string", "null"] }
        }
      }
    }
  }
}
