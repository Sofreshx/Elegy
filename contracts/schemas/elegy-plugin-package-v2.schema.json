{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-plugin-package-v2.schema.json",
  "title": "Elegy Plugin Package V2",
  "description": "Portable package metadata for bundling Elegy skills, piloting contracts, deterministic configuration templates/profiles, MCP projection metadata, docs, assets, and Holon-compatible publishing metadata for host-governed import.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "identity", "components"],
  "properties": {
    "schemaVersion": { "const": "elegy-plugin-package/v2" },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageId", "name", "version"],
      "properties": {
        "packageId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "documentationUri": {
          "type": "string",
          "format": "uri"
        },
        "subsetOf": {
          "type": "array",
          "description": "Capability IDs that this package deliberately subsets from the underlying skill definitions. When declared, every capabilityProjection must reference only capabilities in this set.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skillDefinitions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/skillDefinitionComponent" }
        },
        "capabilityContracts": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "instructionSkills": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "evalPacks": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "resourcePacks": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "toolAdapterContracts": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "bridgeAdapterContracts": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "mcpProjections": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/mcpProjectionComponent" }
        },
        "capabilityProjections": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/capabilityProjectionComponent" }
        },
        "pilotingAdapters": {
          "type": "array",
          "items": { "$ref": "#/$defs/pilotingAdapterComponent" }
        },
        "fixturePacks": {
          "type": "array",
          "items": { "$ref": "#/$defs/fixturePackComponent" }
        },
        "docs": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "assets": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "cliHelpers": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "configurationTemplates": {
          "type": "array",
          "items": { "$ref": "#/$defs/configurationComponent" }
        },
        "configurationProfiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/configurationComponent" }
        },
        "toolRequirements": {
          "type": "array",
          "description": "Required CLI tools and MCP surfaces this package needs installed and probeable.",
          "items": { "$ref": "#/$defs/toolRequirementComponent" }
        },
        "hostCompatibility": {
          "type": "array",
          "description": "Host compatibility hints for target harnesses and version ranges.",
          "items": { "$ref": "#/$defs/compatibilityMetadata" }
        }
      }
    },
    "hostPolicyHints": {
      "$ref": "elegy-plugin-package-v1.schema.json#/properties/hostPolicyHints"
    },
    "publishing": {
      "$ref": "#/$defs/publishingMetadata"
    }
  },
  "$defs": {
    "configurationComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "elegy-plugin-package-v1.schema.json#/$defs/relativePath"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pilotingAdapterComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "manifestRef": {
          "$ref": "elegy-plugin-package-v1.schema.json#/$defs/relativePath"
        },
        "manifest": {
          "$ref": "piloting-adapter-manifest.schema.json"
        }
      },
      "anyOf": [
        { "required": ["manifestRef"] },
        { "required": ["manifest"] }
      ]
    },
    "fixturePackComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "fixturePackRef": {
          "$ref": "elegy-plugin-package-v1.schema.json#/$defs/relativePath"
        },
        "fixturePack": {
          "$ref": "piloting-fixture-pack.schema.json"
        }
      },
      "anyOf": [
        { "required": ["fixturePackRef"] },
        { "required": ["fixturePack"] }
      ]
    },
    "toolRequirementComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toolName", "cliBinary"],
      "properties": {
        "toolName": {
          "type": "string",
          "minLength": 1,
          "description": "Stable tool name for this requirement (e.g. 'elegy-planning')."
        },
        "cliBinary": {
          "type": "string",
          "minLength": 1,
          "description": "CLI binary name to resolve and probe (e.g. 'elegy-planning')."
        },
        "minVersion": {
          "type": "string",
          "description": "Optional minimum version string."
        },
        "probeCommand": {
          "type": "string",
          "description": "Optional override for the probe command (defaults to '--version')."
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "compatibilityMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "versionRange"],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "versionRange": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "publishingMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "marketplaceTarget": {
          "type": "string",
          "enum": ["holon"]
        },
        "importMode": {
          "type": "string",
          "enum": ["package", "dry_run"]
        },
        "sourceRepository": {
          "type": "string",
          "format": "uri"
        },
        "sourceRef": {
          "type": "string",
          "minLength": 1
        },
        "sourceCommit": {
          "type": "string",
          "minLength": 1
        },
        "changelogRef": {
          "$ref": "elegy-plugin-package-v1.schema.json#/$defs/relativePath"
        },
        "provenanceRef": {
          "$ref": "elegy-plugin-package-v1.schema.json#/$defs/relativePath"
        },
        "signatureRefs": {
          "type": "array",
          "items": {
            "$ref": "elegy-plugin-package-v1.schema.json#/$defs/relativePath"
          },
          "uniqueItems": true
        },
        "compatibility": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/compatibilityMetadata"
          }
        }
      }
    }
  }
}
