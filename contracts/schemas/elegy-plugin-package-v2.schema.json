{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-plugin-package-v2.schema.json",
  "title": "Elegy Plugin Package V2",
  "description": "Portable package metadata for bundling Elegy skills, instruction skills, deterministic configuration templates/profiles, MCP projection metadata, docs, and assets for host-governed import.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "identity", "components"],
  "properties": {
    "schemaVersion": { "const": "elegy-plugin-package/v2" },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageId", "name", "version"],
      "properties": {
        "packageId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "documentationUri": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skillDefinitions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/skillDefinitionComponent" }
        },
        "instructionSkills": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "mcpProjections": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/mcpProjectionComponent" }
        },
        "capabilityProjections": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/capabilityProjectionComponent" }
        },
        "docs": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "assets": {
          "type": "array",
          "items": { "$ref": "elegy-plugin-package-v1.schema.json#/$defs/pathComponent" }
        },
        "configurationTemplates": {
          "type": "array",
          "items": { "$ref": "#/$defs/configurationComponent" }
        },
        "configurationProfiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/configurationComponent" }
        }
      }
    },
    "hostPolicyHints": {
      "$ref": "elegy-plugin-package-v1.schema.json#/properties/hostPolicyHints"
    }
  },
  "$defs": {
    "configurationComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "elegy-plugin-package-v1.schema.json#/$defs/relativePath"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
