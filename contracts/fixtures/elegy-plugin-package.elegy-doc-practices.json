{
  "schemaVersion": "elegy-plugin-package/v1",
  "identity": {
    "packageId": "elegy.doc-practices-plugin",
    "name": "elegy-doc-practices",
    "version": "0.1.0",
    "displayName": "Elegy Documentation Practices Plugin"
  },
  "metadata": {
    "description": "Portable plugin package for the central Elegy documentation doctrine: ADR/spec classification, scaffolding, objective validation, and downstream adoption.",
    "tags": ["documentation", "doctrine", "adr", "spec", "validation", "adoption", "plugin"],
    "license": "Apache-2.0",
    "documentationUri": "https://github.com/Sofreshx/Elegy/blob/main/docs/architecture/documentation-practices.md"
  },
  "components": {
    "skillDefinitions": [
      {
        "id": "doc-practices-skill",
        "definitionRef": "skill.elegy-doc-practices.json"
      }
    ],
    "instructionSkills": [
      {
        "id": "elegy-doc-practices-instructions",
        "path": "instruction-skills/elegy-doc-practices.SKILL.md",
        "description": "Central doctrine SKILL.md for ADR/spec classification, placement, and adoption."
      }
    ],
    "capabilityProjections": [
      {
        "id": "doc-practices-classify-cli",
        "skill": "elegy.doc-practices",
        "capability": "doc-practices-classify",
        "lane": "subprocess",
        "supportsDryRun": true,
        "sideEffectClass": "read_only",
        "projection": {
          "projections": ["function_calling", "cli"],
          "functionName": "doc_practices_classify"
        }
      },
      {
        "id": "doc-practices-scaffold-adr-cli",
        "skill": "elegy.doc-practices",
        "capability": "doc-practices-scaffold-adr",
        "lane": "subprocess",
        "supportsDryRun": true,
        "sideEffectClass": "disk_write",
        "projection": {
          "projections": ["function_calling", "cli"],
          "functionName": "doc_practices_scaffold_adr"
        }
      },
      {
        "id": "doc-practices-scaffold-spec-cli",
        "skill": "elegy.doc-practices",
        "capability": "doc-practices-scaffold-spec",
        "lane": "subprocess",
        "supportsDryRun": true,
        "sideEffectClass": "disk_write",
        "projection": {
          "projections": ["function_calling", "cli"],
          "functionName": "doc_practices_scaffold_spec"
        }
      },
      {
        "id": "doc-practices-validate-cli",
        "skill": "elegy.doc-practices",
        "capability": "doc-practices-validate",
        "lane": "subprocess",
        "supportsDryRun": true,
        "sideEffectClass": "read_only",
        "projection": {
          "projections": ["function_calling", "cli"],
          "functionName": "doc_practices_validate"
        }
      },
      {
        "id": "doc-practices-init-cli",
        "skill": "elegy.doc-practices",
        "capability": "doc-practices-init",
        "lane": "subprocess",
        "supportsDryRun": true,
        "sideEffectClass": "disk_write",
        "projection": {
          "projections": ["function_calling", "cli"],
          "functionName": "doc_practices_init"
        }
      }
    ],
    "docs": [
      {
        "id": "doc-practices-architecture",
        "path": "docs/architecture/documentation-practices.md"
      },
      {
        "id": "doc-practices-spec",
        "path": "docs/specs/documentation-practices-skill-and-cli.md"
      },
      {
        "id": "doc-practices-adr",
        "path": "docs/adr/2026-05-25-centralize-documentation-practices-doctrine.md"
      }
    ],
    "toolRequirements": [
      {
        "toolName": "elegy-documentation",
        "cliBinary": "elegy-documentation",
        "minVersion": "0.1.0",
        "probeCommand": "--version",
        "description": "Dedicated documentation authority CLI for inspect, map, check, init, and export."
      },
      {
        "toolName": "elegy",
        "cliBinary": "elegy",
        "minVersion": "0.1.0",
        "probeCommand": "--version",
        "description": "Umbrella CLI exposing the docs new adr/spec scaffold commands."
      }
    ]
  },
  "hostPolicyHints": {
    "sideEffectClass": "disk_write",
    "requiresApproval": false,
    "policyTags": ["documentation-authority", "centralized-doctrine", "objective-validation"]
  },
  "elegyCompatibility": {
    "contractBundleVersion": "1.8.0",
    "schemaLine": "1.x"
  }
}
