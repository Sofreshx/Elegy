        "definitionRef": "skill.elegy-memory.json"
      }
    ],
    "capabilityProjections": [
      {
        "id": "memory-add-cli",
        "skill": "elegy.memory",
        "capability": "memory-add",
        "lane": "subprocess",
        "supportsDryRun": false,
        "sideEffectClass": "disk_write",
        "projection": {
          "projections": ["function_calling", "cli"],
          "functionName": "memory_add"
        }
      },
      {
        "id": "memory-search-cli",
        "skill": "elegy.memory",
