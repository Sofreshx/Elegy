          "projections": ["function_calling", "cli"],
          "functionName": "memory_list"
        }
      },
      {
        "id": "memory-inspect-cli",
        "skill": "elegy.memory",
        "capability": "memory-inspect",
        "lane": "subprocess",
        "supportsDryRun": true,
        "sideEffectClass": "read_only",
        "projection": {
          "projections": ["function_calling", "cli"],
          "functionName": "memory_inspect"
