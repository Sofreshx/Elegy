{
  "schemaVersion": "elegy-plugin-package/v1",
  "identity": {
    "packageId": "elegy.memory-plugin",
    "name": "elegy-memory",
    "version": "0.1.0",
    "displayName": "Elegy Memory Plugin"
  },
  "metadata": {
    "description": "Portable memory package fixture for bounded local non-authoritative memory operations over the Elegy memory CLI surface.",
    "tags": ["memory", "local-cli", "mvp", "preview", "non-authoritative", "plugin"],
    "license": "Apache-2.0",
    "documentationUri": "https://github.com/Sofreshx/Elegy/blob/main/rust/features/elegy-memory/docs/architecture/ARCHITECTURE.md"
  },
  "components": {
