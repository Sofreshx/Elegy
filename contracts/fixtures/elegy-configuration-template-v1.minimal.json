{
  "schemaVersion": "elegy-configuration-template/v1",
  "templateId": "repo-skill-mirror-minimal",
  "displayName": "Repo Skill Mirror Minimal",
  "description": "Mirror canonical repo-local skill authority into a selected harness-local path.",
  "harness": "generic",
  "scope": "repo",
  "bindings": {
    "authority.skills": {
      "defaultValue": ".github/skills",
      "required": true,
      "description": "Canonical repo-local skill authority root."
    },
    "target.skills": {
      "defaultValue": ".agents/skills",
      "required": true,
      "description": "Mirror root for the selected harness."
    }
  },
  "operations": [
    {
      "operationType": "mirrorDirectory",
      "operationId": "mirror-skills",
      "family": "skill",
      "source": {
        "base": "target-root",
        "path": "${authority.skills}"
      },
      "destination": {
        "base": "target-root",
        "path": "${target.skills}"
      },
      "prune": true
    }
  ]
}
