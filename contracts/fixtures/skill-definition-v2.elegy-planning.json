  "metadata": {
    "displayName": "Elegy Planning Authority",
    "description": "Durable planning authority for goals, roadmaps, plans, todos, issues, review points, validation, and projection rendering.",
    "summary": "Create and inspect durable planning records over Elegy's dedicated planning CLI.",
    "category": "planning",
    "author": "Elegy Contributors",
    "license": "Apache-2.0",
    "tags": ["planning", "goal", "roadmap", "plan", "todo", "issue", "review", "validation", "projection", "sqlite"],
    "owners": ["elegy"],
    "documentationUri": "rust/crates/elegy-planning/docs/architecture/ARCHITECTURE.md"
  },
  "capabilities": [
    {
      "id": "planning-goal-create",
      "name": "Create Goal",
      "description": "Create a durable goal with explicit acceptance and rejection criteria.",
      "implementation": {
        "executionType": "subprocess",
        "executableName": "elegy-planning",
        "arguments": ["--db", "${db}", "--non-interactive", "--correlation-id", "${correlation_id}", "--json", "goal", "create", "--id", "${id}", "--title", "${title}", "--description", "${description}", "--acceptance", "${acceptance}", "--rejection", "${rejection}", "--status", "${status}", "--tag", "${tags}"]
      },
      "input": {
        "parameters": [
          {
            "name": "db",
            "type": "path",
            "description": "Optional SQLite database path for planning state.",
            "required": false
          },
          {
            "name": "correlation_id",
            "type": "string",
            "description": "Correlation ID required for machine-safe goal authoring.",
            "required": true
          },
          {
            "name": "id",
            "type": "string",
            "description": "Optional stable goal identifier.",
            "required": false
          },
          {
            "name": "title",
            "type": "string",
            "description": "Goal title.",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "description": "Goal description.",
            "required": true
          },
          {
            "name": "acceptance",
            "type": "array",
            "description": "One or more acceptance criteria.",
            "required": true
          },
          {
            "name": "rejection",
            "type": "array",
            "description": "One or more rejection criteria.",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "description": "Optional goal status: draft, proposed, active, validated, invalidated, superseded, or abandoned.",
            "required": false,
            "default": "draft"
          },
          {
            "name": "tags",
            "type": "array",
            "description": "Optional repeated goal tags.",
            "required": false
          }
        ]
      },
      "output": {
        "resultType": "PlanningResult",
        "schemaRef": "https://elegy/contracts/schemas/planning-result.schema.json",
        "description": "Created goal record and validation state."
      },
      "execution": {
        "mode": "requestResponse",
        "isDeterministic": false,
        "hasSideEffects": true
      }
    },
