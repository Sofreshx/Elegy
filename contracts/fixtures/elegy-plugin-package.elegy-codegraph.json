{
  "schemaVersion": "elegy-plugin-package/v1",
  "identity": {
    "packageId": "elegy.codegraph-plugin",
    "name": "elegy-codegraph",
    "version": "0.1.0",
    "displayName": "Elegy Codegraph Plugin"
  },
  "metadata": {
    "description": "Portable codebase graph extraction and query CLI for TypeScript and Rust. Powered by the `elegy-codegraph` Rust crate, which exposes a host-neutral JSON contract and backs the schema at `contracts/schemas/elegy-codegraph.graph.v0.json`.",
    "tags": ["codegraph", "graph", "extraction", "query", "typescript", "rust"],
    "license": "Apache-2.0",
    "documentationUri": "https://github.com/Sofreshx/Elegy/blob/main/rust/features/elegy-codegraph/docs/specs/plugin-research.md"
  },
  "components": {
    "skillDefinitions": [
      {
        "id": "codegraph-skill",
        "definitionRef": "skill.elegy-codegraph.json"
      }
    ],
    "capabilityProjections": [
      {
        "id": "codegraph-extract",
        "skill": "elegy.codegraph",
        "capability": "codegraph-extract",
        "lane": "subprocess",
        "supportsDryRun": false,
        "sideEffectClass": "disk_write",
        "projection": {
          "projections": ["function_calling", "cli"],
          "functionName": "codegraph_extract"
        }
      },
      {
        "id": "codegraph-query",
        "skill": "elegy.codegraph",
        "capability": "codegraph-query",
        "lane": "subprocess",
        "supportsDryRun": true,
        "sideEffectClass": "read_only",
        "projection": {
          "projections": ["function_calling", "cli"],
          "functionName": "codegraph_query"
        }
      }
    ],
    "toolRequirements": [
      {
        "toolName": "elegy-codegraph",
        "cliBinary": "elegy-codegraph"
      }
    ]
  },
  "hostPolicyHints": {
    "sideEffectClass": "disk_write",
    "policyTags": ["codegraph-authority", "deterministic-extraction"]
  },
  "publishing": {
    "cratePath": "elegy-codegraph",
    "assetKind": "cli",
    "marketplaceTarget": "github-releases",
    "importMode": "package",
    "sourceRepository": "https://github.com/Sofreshx/Elegy",
    "sourceRef": "main",
    "compatibility": [],
    "archiveFamily": "elegy-codegraph",
    "assetPrefix": "elegy-codegraph",
    "targets": null
  },
  "elegyCompatibility": {
    "contractBundleVersion": "1.8.0",
    "schemaLine": "1.x"
  }
}
