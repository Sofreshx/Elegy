{
  "skillFormat": "elegy-skill-definition",
  "skillVersion": 1,
  "identity": {
    "namespace": "elegy",
    "name": "diagram",
    "version": "0.1.0"
  },
  "metadata": {
    "displayName": "Elegy Semantic Diagram Tools",
    "description": "Exposes Elegy's semantic diagram capability, allowing agents to understand, edit, and project structured visual concepts without managing UI layouts or coordinates.",
    "category": "design",
    "author": "Elegy Contributors",
    "license": "Apache-2.0"
  },
  "capabilities": [
    {
      "id": "diagram-create",
      "name": "Create Diagram",
      "description": "Initializes an empty semantic diagram.",
      "implementation": {
        "executionType": "subprocess",
        "executableName": "elegy",
        "arguments": [
          "diagram",
          "create",
          "--diagram-type",
          "${type}",
          "--json"
        ]
      }
    },
    {
      "id": "diagram-patch",
      "name": "Patch Diagram",
      "description": "Surgically add or remove nodes/edges from an existing diagram file.",
      "implementation": {
        "executionType": "subprocess",
        "executableName": "elegy",
        "arguments": [
          "diagram",
          "patch",
          "--input",
          "${inputPath}",
          "--add-node",
          "${addNode}",
          "--add-edge",
          "${addEdge}",
          "--remove-node",
          "${removeNode}",
          "--remove-edge",
          "${removeEdge}",
          "--json"
        ]
      }
    },
    {
      "id": "diagram-narrate",
      "name": "Narrate Diagram",
      "description": "Reads a semantic diagram and returns a textual, human-readable summary of the nodes and relations.",
      "implementation": {
        "executionType": "subprocess",
        "executableName": "elegy",
        "arguments": [
          "diagram",
          "narrate",
          "--input",
          "${inputPath}",
          "--json"
        ]
      }
    },
    {
      "id": "diagram-render",
      "name": "Render Diagram",
      "description": "Transforms a semantic diagram into a string format like Mermaid.js.",
      "implementation": {
        "executionType": "subprocess",
        "executableName": "elegy",
        "arguments": [
          "diagram",
          "render",
          "--input",
          "${inputPath}",
          "--render-format",
          "${format}",
          "--json"
        ]
      }
    }
  ]
}
