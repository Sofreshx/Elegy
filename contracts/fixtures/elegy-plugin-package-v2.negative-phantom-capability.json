{
  "schemaVersion": "elegy-plugin-package/v2",
  "identity": {
    "packageId": "elegy.test.negative-phantom-capability",
    "name": "negative-phantom-capability",
    "version": "0.1.0",
    "displayName": "Negative Test: Phantom Capability"
  },
  "metadata": {
    "description": "Negative fixture: capabilityProjection references a capability not in any skill definition.",
    "tags": ["test", "negative"],
    "license": "MIT"
  },
  "components": {
    "skillDefinitions": [
      {
        "id": "test-skill",
        "definition": {
          "skillFormat": "elegy-skill-definition",
          "skillVersion": 2,
          "identity": {
            "namespace": "test",
            "name": "test-skill",
            "version": "1.0.0"
          },
          "capabilities": [
            {
              "id": "real-capability",
              "name": "Real Capability",
              "description": "A real capability."
            }
          ],
          "lifecycleState": "active"
        }
      }
    ],
    "capabilityProjections": [
      {
        "id": "phantom-projection",
        "skill": "test.test-skill",
        "capability": "nonexistent-capability",
        "lane": "cli",
        "supportsDryRun": false
      }
    ]
  }
}
