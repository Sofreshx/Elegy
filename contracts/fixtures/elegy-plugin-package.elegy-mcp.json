{
  "schemaVersion": "elegy-plugin-package/v1",
  "identity": {
    "packageId": "elegy.mcp-plugin",
    "name": "elegy-mcp",
    "version": "0.1.0",
    "displayName": "Elegy MCP Plugin"
  },
  "metadata": {
    "description": "Portable MCP descriptor authoring and analysis plugin. Wraps the reusable author/analyze behavior in rust/core/elegy-tooling over governed MCP descriptors under contracts/schemas/mcp-*.schema.json and contracts/fixtures/mcp-*.json.",
    "tags": ["mcp", "authoring", "analysis", "plugin"],
    "license": "Apache-2.0",
    "documentationUri": "https://github.com/Sofreshx/Elegy/blob/main/rust/features/elegy-mcp/docs/architecture/ARCHITECTURE.md"
  },
  "components": {
    "skillDefinitions": [
      {
        "id": "mcp-skill",
        "definitionRef": "skill.elegy-mcp.json"
      }
    ],
    "capabilityProjections": [
      {
        "id": "mcp-author-cli",
        "skill": "elegy.mcp",
        "capability": "mcp-author",
        "lane": "subprocess",
        "supportsDryRun": true,
        "sideEffectClass": "read_only",
        "projection": {
          "projections": ["function_calling", "cli"],
          "functionName": "mcp_author"
        }
      },
      {
        "id": "mcp-analyze-cli",
        "skill": "elegy.mcp",
        "capability": "mcp-analyze",
        "lane": "subprocess",
        "supportsDryRun": true,
        "sideEffectClass": "read_only",
        "projection": {
          "projections": ["function_calling", "cli"],
          "functionName": "mcp_analyze"
        }
      }
    ],
    "toolRequirements": [
      {
        "toolName": "elegy-mcp",
        "cliBinary": "elegy-mcp",
        "minVersion": "0.1.0",
        "probeCommand": "--version",
        "description": "Elegy MCP CLI for descriptor authoring and analysis."
      }
    ],
    "docs": [
      {
        "id": "mcp-architecture",
        "path": "rust/features/elegy-mcp/docs/architecture/ARCHITECTURE.md"
      }
    ]
  },
  "hostPolicyHints": {
    "sideEffectClass": "read_only",
    "requiresApproval": false,
    "policyTags": ["mcp-authority", "descriptor-validation"]
  },
  "publishing": {
    "cratePath": "elegy-mcp",
    "assetKind": "wrapper",
    "marketplaceTarget": "github-releases",
    "importMode": "package",
    "sourceRepository": "https://github.com/Sofreshx/Elegy",
    "sourceRef": "main",
    "compatibility": [],
    "archiveFamily": "elegy-mcp-wrapper",
    "assetPrefix": "elegy-mcp-wrapper",
    "skillBridge": "skills/elegy-mcp/SKILL.md",
    "installer": "install.sh",
    "prePublishHook": null,
    "postPublishHook": null,
    "targets": null
  },
  "elegyCompatibility": {
    "contractBundleVersion": "1.8.0",
    "schemaLine": "1.x"
  }
}
