#!/usr/bin/env bash
# NOTE: This hook has been migrated to the repo-root .githooks/ directory.
# The active pre-push hook is now at .githooks/pre-push.
# Use scripts/setup-hooks.ps1 to configure git to use the new hooks location.
# This file is retained for reference.
# Pre-push hook: enforce fmt + clippy before pushing to remote.
# Install with: ln -sf .git-hooks/pre-push .git/hooks/pre-push
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
RUST_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

echo "[pre-push] cargo fmt --all --check"
(cd "$RUST_DIR" && cargo fmt --all --check)

echo "[pre-push] cargo clippy --workspace --all-targets --all-features -- -D warnings"
(cd "$RUST_DIR" && cargo clippy --workspace --all-targets --all-features -- -D warnings)

echo "[pre-push] OK"
