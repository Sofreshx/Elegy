{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/structured-failure.schema.json",
  "title": "StructuredFailure",
  "description": "Reusable machine-readable failure contract for governed execution, CLI, and adapter surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "message", "category", "retryable"],
  "properties": {
    "code": { "type": "string", "minLength": 1 },
    "message": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": [
        "invalidInput",
        "policy",
        "authentication",
        "authorization",
        "timeout",
        "dependency",
        "unavailable",
        "conflict",
        "internal",
        "unknown"
      ]
    },
    "retryable": { "type": "boolean" },
    "correlationId": { "type": ["string", "null"] },
    "details": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "cause": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
