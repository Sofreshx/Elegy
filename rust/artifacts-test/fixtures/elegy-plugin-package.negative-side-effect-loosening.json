{
  "schemaVersion": "elegy-plugin-package/v1",
  "identity": {
    "packageId": "elegy.test.negative-side-effect-loosening",
    "name": "negative-side-effect-loosening",
    "version": "0.1.0",
    "displayName": "Negative Test: Side Effect Loosening"
  },
  "metadata": {
    "description": "Negative fixture: capabilityProjection declares a weaker sideEffectClass than the skill's hostProjection.",
    "tags": ["test", "negative"],
    "license": "MIT"
  },
  "components": {
    "skillDefinitions": [
      {
        "id": "side-effect-skill",
        "definition": {
          "skillFormat": "elegy-skill-definition",
          "skillVersion": 2,
          "identity": {
            "namespace": "test",
            "name": "side-effect-skill",
            "version": "1.0.0"
          },
          "capabilities": [
            {
              "id": "disk-write-cap",
              "name": "Disk Write Cap",
              "description": "Writes to disk."
            }
          ],
          "lifecycleState": "active",
          "hostProjection": {
            "cliName": "side-effect-tool",
            "outputContractId": "side-effect-v1",
            "defaultSideEffectClass": "disk_write",
            "capabilityProjections": [
              {
                "capabilityId": "disk-write-cap",
                "functionName": "disk_write_cap",
                "sideEffectClass": "disk_write"
              }
            ]
          }
        }
      }
    ],
    "capabilityProjections": [
      {
        "id": "loosened-projection",
        "skill": "test.side-effect-skill",
        "capability": "disk-write-cap",
        "lane": "cli",
        "supportsDryRun": false,
        "sideEffectClass": "read_only"
      }
    ]
  }
}
