{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/execution-event.schema.json",
  "title": "ExecutionEvent",
  "description": "Capability-level execution event record for governed invocation lifecycle tracking outside agent-conversation-specific streaming surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "requestId",
    "executionId",
    "sequence",
    "timestamp",
    "eventType",
    "status"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "requestId": { "type": "string", "minLength": 1 },
    "executionId": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "eventType": {
      "type": "string",
      "enum": [
        "accepted",
        "started",
        "progress",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed", "cancelled"]
    },
    "correlationId": { "type": ["string", "null"] },
    "traceRef": { "type": ["string", "null"] },
    "capabilityId": { "type": ["string", "null"] },
    "message": { "type": ["string", "null"] },
    "progress": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["current", "total"],
      "properties": {
        "current": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 },
        "unit": { "type": ["string", "null"] }
      }
    },
    "failure": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["code", "message", "category", "retryable"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": [
            "invalidInput",
            "policy",
            "authentication",
            "authorization",
            "timeout",
            "dependency",
            "unavailable",
            "conflict",
            "internal",
            "unknown"
          ]
        },
        "retryable": { "type": "boolean" },
        "correlationId": { "type": ["string", "null"] },
        "details": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "cause": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
