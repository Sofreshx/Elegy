{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/memory-contradictions-result.schema.json",
  "title": "MemoryContradictionsResult",
  "description": "List of unresolved contradiction records for the configured memory scope.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "memoryAId", "memoryBId", "detectedAt", "description", "resolutionStatus"],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "memoryAId": { "type": "string", "minLength": 1 },
      "memoryBId": { "type": "string", "minLength": 1 },
      "detectedAt": { "type": "string", "format": "date-time" },
      "description": { "type": "string" },
      "resolutionStatus": { "type": "string" },
      "resolvedAt": { "type": ["string", "null"], "format": "date-time" },
      "resolutionNote": { "type": ["string", "null"] }
    }
  }
}
