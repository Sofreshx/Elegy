{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/agent-manifest.schema.json",
  "title": "Elegy Agent Manifest Payload",
  "description": "Data payload emitted by `elegy agent manifest --json` for host onboarding.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "integrationVersion",
    "elegyVersion",
    "cliSchemaVersion",
    "profile",
    "contracts",
    "discovery",
    "invocation",
    "mcp",
    "selected"
  ],
  "properties": {
    "integrationVersion": { "type": "string", "const": "elegy.agent/v1" },
    "elegyVersion": { "type": "string", "minLength": 1 },
    "cliSchemaVersion": { "type": "string", "minLength": 1 },
    "profile": { "$ref": "#/$defs/profileSummary" },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skillDefinition", "agentCapabilityProfile", "machineEnvelope"],
      "properties": {
        "skillDefinition": { "type": "string", "const": "2.0.0" },
        "agentCapabilityProfile": { "type": "string", "const": "agent-capability-profile/v1" },
        "machineEnvelope": { "type": "string", "minLength": 1 }
      }
    },
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "defaultCommand", "queryCommand", "detailCommand", "profileFlag"],
      "properties": {
        "authority": { "type": "string", "minLength": 1 },
        "defaultCommand": { "type": "string", "minLength": 1 },
        "queryCommand": { "type": "string", "minLength": 1 },
        "detailCommand": { "type": "string", "minLength": 1 },
        "profileFlag": { "type": "string", "minLength": 1 }
      }
    },
    "invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultPath", "templateSource", "sideEffectPolicy"],
      "properties": {
        "defaultPath": { "type": "string", "const": "cli" },
        "templateSource": { "type": "string", "minLength": 1 },
        "sideEffectPolicy": { "type": "string", "minLength": 1 }
      }
    },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["optional", "startupCommand", "role"],
      "properties": {
        "optional": { "type": "boolean", "const": true },
        "startupCommand": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 }
      }
    },
    "selected": { "$ref": "#/$defs/selectedSummary" }
  },
  "$defs": {
    "profileSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profileProvided",
        "profilePath",
        "profileId",
        "schemaVersion",
        "alwaysIncludeRouter",
        "routerAvailable",
        "selectedSkillCount",
        "selectedCapabilityCount",
        "totalSkillCount",
        "totalCapabilityCount"
      ],
      "properties": {
        "profileProvided": { "type": "boolean" },
        "profilePath": { "type": ["string", "null"] },
        "profileId": { "type": ["string", "null"] },
        "schemaVersion": { "type": ["string", "null"] },
        "alwaysIncludeRouter": { "type": "boolean" },
        "routerAvailable": { "type": "boolean" },
        "selectedSkillCount": { "type": "integer", "minimum": 0 },
        "selectedCapabilityCount": { "type": "integer", "minimum": 0 },
        "totalSkillCount": { "type": "integer", "minimum": 0 },
        "totalCapabilityCount": { "type": "integer", "minimum": 0 }
      }
    },
    "selectedSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skills", "capabilities"],
      "properties": {
        "skills": {
          "type": "array",
          "items": { "$ref": "#/$defs/selectedSkill" }
        },
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/selectedCapability" }
        }
      }
    },
    "selectedSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "category", "capabilitiesCount", "lifecycleState"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "capabilitiesCount": { "type": "integer", "minimum": 0 },
        "lifecycleState": { "type": "string", "minLength": 1 }
      }
    },
    "selectedCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "skillId", "name", "hasSideEffects"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "skillId": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "hasSideEffects": { "type": "boolean" }
      }
    }
  }
}