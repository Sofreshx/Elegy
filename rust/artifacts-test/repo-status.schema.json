{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/repo-status.schema.json",
  "title": "RepoStatus",
  "description": "Structured read-only repository status summary with branch tracking, changed entries, and staged/unstaged/untracked counts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["repoRoot", "ahead", "behind", "entries", "stagedCount", "unstagedCount", "untrackedCount"],
  "properties": {
    "repoRoot": { "type": "string", "minLength": 1 },
    "currentBranch": { "type": ["string", "null"] },
    "upstream": { "type": ["string", "null"] },
    "ahead": { "type": "integer", "minimum": 0 },
    "behind": { "type": "integer", "minimum": 0 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "indexStatus", "worktreeStatus"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "indexStatus": { "type": "string" },
          "worktreeStatus": { "type": "string" }
        }
      }
    },
    "stagedCount": { "type": "integer", "minimum": 0 },
    "unstagedCount": { "type": "integer", "minimum": 0 },
    "untrackedCount": { "type": "integer", "minimum": 0 }
  }
}
