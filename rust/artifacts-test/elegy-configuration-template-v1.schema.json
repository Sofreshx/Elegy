{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/elegy-configuration-template-v1.schema.json",
  "title": "Elegy Configuration Template V1",
  "description": "Governed deterministic template for materializing agentic assets into harness, repo, or workspace targets.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "templateId", "scope", "operations"],
  "properties": {
    "schemaVersion": { "const": "elegy-configuration-template/v1" },
    "templateId": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "harness": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "enum": ["user-global", "repo", "workspace"]
    },
    "bindings": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/bindingDefinition"
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/operation" }
    }
  },
  "$defs": {
    "bindingDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "defaultValue": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "assetFamily": {
      "type": "string",
      "enum": ["instruction", "skill", "agent", "mcp", "hook", "support-file"]
    },
    "pathBase": {
      "type": "string",
      "enum": ["target-root", "template-root"]
    },
    "pathRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "path"],
      "properties": {
        "base": { "$ref": "#/$defs/pathBase" },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "operationBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operationType", "operationId", "family"],
      "properties": {
        "operationType": {
          "type": "string",
          "enum": [
            "copyFile",
            "copyDirectory",
            "mirrorDirectory",
            "patchTextBlock",
            "mergeJson",
            "patchTomlBlock"
          ]
        },
        "operationId": {
          "type": "string",
          "minLength": 1
        },
        "family": { "$ref": "#/$defs/assetFamily" }
      }
    },
    "copyFileOperation": {
      "allOf": [
        { "$ref": "#/$defs/operationBase" },
        {
          "properties": {
            "operationType": { "const": "copyFile" },
            "source": { "$ref": "#/$defs/pathRef" },
            "destination": { "$ref": "#/$defs/pathRef" }
          },
          "required": ["source", "destination"]
        }
      ]
    },
    "copyDirectoryOperation": {
      "allOf": [
        { "$ref": "#/$defs/operationBase" },
        {
          "properties": {
            "operationType": { "const": "copyDirectory" },
            "source": { "$ref": "#/$defs/pathRef" },
            "destination": { "$ref": "#/$defs/pathRef" }
          },
          "required": ["source", "destination"]
        }
      ]
    },
    "mirrorDirectoryOperation": {
      "allOf": [
        { "$ref": "#/$defs/operationBase" },
        {
          "properties": {
            "operationType": { "const": "mirrorDirectory" },
            "source": { "$ref": "#/$defs/pathRef" },
            "destination": { "$ref": "#/$defs/pathRef" },
            "prune": { "type": "boolean" }
          },
          "required": ["source", "destination"]
        }
      ]
    },
    "patchTextBlockOperation": {
      "allOf": [
        { "$ref": "#/$defs/operationBase" },
        {
          "properties": {
            "operationType": { "const": "patchTextBlock" },
            "destination": { "$ref": "#/$defs/pathRef" },
            "startMarker": {
              "type": "string",
              "minLength": 1
            },
            "endMarker": {
              "type": "string",
              "minLength": 1
            },
            "content": {
              "type": "string",
              "minLength": 1
            },
            "contentPath": { "$ref": "#/$defs/pathRef" },
            "createIfMissing": { "type": "boolean" }
          },
          "required": ["destination", "startMarker", "endMarker"],
          "oneOf": [
            { "required": ["content"] },
            { "required": ["contentPath"] }
          ]
        }
      ]
    },
    "mergeJsonOperation": {
      "allOf": [
        { "$ref": "#/$defs/operationBase" },
        {
          "properties": {
            "operationType": { "const": "mergeJson" },
            "destination": { "$ref": "#/$defs/pathRef" },
            "value": {
              "type": "object"
            },
            "source": { "$ref": "#/$defs/pathRef" }
          },
          "required": ["destination"],
          "oneOf": [
            { "required": ["value"] },
            { "required": ["source"] }
          ]
        }
      ]
    },
    "patchTomlBlockOperation": {
      "allOf": [
        { "$ref": "#/$defs/operationBase" },
        {
          "properties": {
            "operationType": { "const": "patchTomlBlock" },
            "destination": { "$ref": "#/$defs/pathRef" },
            "startMarker": {
              "type": "string",
              "minLength": 1
            },
            "endMarker": {
              "type": "string",
              "minLength": 1
            },
            "content": {
              "type": "string",
              "minLength": 1
            },
            "contentPath": { "$ref": "#/$defs/pathRef" },
            "createIfMissing": { "type": "boolean" }
          },
          "required": ["destination", "startMarker", "endMarker"],
          "oneOf": [
            { "required": ["content"] },
            { "required": ["contentPath"] }
          ]
        }
      ]
    },
    "operation": {
      "oneOf": [
        { "$ref": "#/$defs/copyFileOperation" },
        { "$ref": "#/$defs/copyDirectoryOperation" },
        { "$ref": "#/$defs/mirrorDirectoryOperation" },
        { "$ref": "#/$defs/patchTextBlockOperation" },
        { "$ref": "#/$defs/mergeJsonOperation" },
        { "$ref": "#/$defs/patchTomlBlockOperation" }
      ]
    }
  }
}
