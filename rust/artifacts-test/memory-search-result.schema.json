{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/memory-search-result.schema.json",
  "title": "MemorySearchResult",
  "description": "Search results from the memory store with scores and memory previews.",
  "type": "object",
  "additionalProperties": false,
  "required": ["scope", "query", "keywordOnly", "includeDormant", "results"],
  "properties": {
    "scope": { "type": "string", "minLength": 1 },
    "query": { "type": "string" },
    "keywordOnly": { "type": "boolean" },
    "includeDormant": { "type": "boolean" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "score", "similarity", "state", "memoryType", "preview"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "score": { "type": "number" },
          "similarity": { "type": "number" },
          "state": { "type": "string" },
          "memoryType": { "type": "string" },
          "preview": { "type": "string" }
        }
      }
    }
  }
}
