{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/memory-health-report.schema.json",
  "title": "MemoryHealthReport",
  "description": "Memory health report with scope statistics, type counts, budget usage, and contradiction/embedding metrics.",
  "type": "object",
  "additionalProperties": false,
  "required": ["report", "typeCounts"],
  "properties": {
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "activeCount", "dormantCount", "totalStorageBytes", "budgetUsageRatio", "unresolvedContradictions", "staleEmbeddingsCount"],
      "properties": {
        "scope": { "type": "string" },
        "activeCount": { "type": "integer", "minimum": 0 },
        "dormantCount": { "type": "integer", "minimum": 0 },
        "totalStorageBytes": { "type": "integer", "minimum": 0 },
        "budgetUsageRatio": { "type": "number" },
        "unresolvedContradictions": { "type": "integer", "minimum": 0 },
        "staleEmbeddingsCount": { "type": "integer", "minimum": 0 },
        "lastConsolidation": { "type": ["string", "null"], "format": "date-time" },
        "oldestActiveMemory": { "type": ["string", "null"], "format": "date-time" },
        "newestMemory": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "typeCounts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 },
      "description": "Map of memory type to count."
    }
  }
}
