{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/memory-add-input.schema.json",
  "title": "MemoryAddInput",
  "description": "Input schema for the memory-add capability.",
  "type": "object",
  "additionalProperties": false,
  "required": ["content"],
  "properties": {
    "content": { "type": "string", "minLength": 1 },
    "memoryType": { "type": "string", "default": "observation" },
    "importance": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.5 },
    "provenance": { "type": "string", "default": "user-stated" },
    "db": { "type": "string" },
    "scope": { "type": "string", "default": "workspace" }
  }
}
