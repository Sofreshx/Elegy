{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/capability-definition.schema.json",
  "title": "CapabilityDefinition",
  "description": "Canonical reusable capability definition contract for governed discovery, routing, and policy-aware execution metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "displayName",
    "version",
    "family",
    "tags",
    "input",
    "output",
    "execution",
    "governance",
    "source",
    "observability",
    "lifecycleState"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "family": {
      "type": "string",
      "enum": ["skill", "mcpTool", "workflowNode", "retrievalSource", "adapter", "custom"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema": { "type": ["object", "boolean", "null"] },
        "schemaRef": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema": { "type": ["object", "boolean", "null"] },
        "schemaRef": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sideEffectClass",
        "authMode",
        "idempotence",
        "costHint",
        "latencyHint"
      ],
      "properties": {
        "sideEffectClass": {
          "type": "string",
          "enum": ["none", "read", "write", "external", "destructive"]
        },
        "authMode": {
          "type": "string",
          "enum": ["none", "delegated", "user", "service", "environment"]
        },
        "idempotence": {
          "type": "string",
          "enum": ["unknown", "conditional", "always", "never"]
        },
        "costHint": {
          "type": "string",
          "enum": ["unknown", "low", "medium", "high"]
        },
        "latencyHint": {
          "type": "string",
          "enum": ["unknown", "interactive", "background", "batch"]
        },
        "timeoutSeconds": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trustLevel", "approvalRequirement", "policyRefs"],
      "properties": {
        "trustLevel": {
          "type": "string",
          "enum": ["untrusted", "sandboxed", "trusted", "privileged"]
        },
        "approvalRequirement": {
          "type": "string",
          "enum": ["none", "advisory", "required"]
        },
        "policyRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceKind"],
      "properties": {
        "sourceKind": {
          "type": "string",
          "enum": ["manual", "imported", "generated", "projected"]
        },
        "sourceRef": { "type": ["string", "null"] },
        "artifactRef": { "type": ["string", "null"] }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["labels", "correlationRequired", "emitsExecutionEvents"],
      "properties": {
        "labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "correlationRequired": { "type": "boolean" },
        "emitsExecutionEvents": { "type": "boolean" }
      }
    },
    "lifecycleState": {
      "type": "string",
      "enum": ["draft", "active", "deprecated", "archived"]
    }
  }
}
