{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/agent-discovery.schema.json",
  "title": "Elegy Agent Discovery Payload",
  "description": "Data payload emitted by `elegy agent discover --json` for profile-filtered capability discovery.",
  "type": "object",
  "additionalProperties": false,
  "required": ["query", "disclosureLevel", "profile", "results", "totalResults"],
  "properties": {
    "query": { "type": ["string", "null"] },
    "disclosureLevel": { "type": "string", "enum": ["index", "detail"] },
    "profile": { "$ref": "#/$defs/profileSummary" },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/discoveryEntry" }
    },
    "totalResults": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "profileSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profileProvided",
        "profilePath",
        "profileId",
        "schemaVersion",
        "alwaysIncludeRouter",
        "routerAvailable",
        "selectedSkillCount",
        "selectedCapabilityCount",
        "totalSkillCount",
        "totalCapabilityCount"
      ],
      "properties": {
        "profileProvided": { "type": "boolean" },
        "profilePath": { "type": ["string", "null"] },
        "profileId": { "type": ["string", "null"] },
        "schemaVersion": { "type": ["string", "null"] },
        "alwaysIncludeRouter": { "type": "boolean" },
        "routerAvailable": { "type": "boolean" },
        "selectedSkillCount": { "type": "integer", "minimum": 0 },
        "selectedCapabilityCount": { "type": "integer", "minimum": 0 },
        "totalSkillCount": { "type": "integer", "minimum": 0 },
        "totalCapabilityCount": { "type": "integer", "minimum": 0 }
      }
    },
    "discoveryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description",
        "category",
        "capabilitiesCount",
        "lifecycleState",
        "expandCommand",
        "expandCommandArgs"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "capabilitiesCount": { "type": "integer", "minimum": 0 },
        "lifecycleState": { "type": "string", "minLength": 1 },
        "expandCommand": { "type": "string", "minLength": 1 },
        "expandCommandArgs": {
          "type": "array",
          "minItems": 6,
          "items": { "type": "string" }
        },
        "matchedCapabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "matchReasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "matchScore": { "type": "number", "minimum": 0 },
        "triggerKeywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/capabilityObject" }
        }
      }
    },
    "capabilityObject": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  }
}