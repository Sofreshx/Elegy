{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/governed-memory-record-projection.schema.json",
  "title": "Governed Memory Record Projection",
  "description": "Deterministic governed projection from a local governed-memory-record back to the unchanged summary-only-session-context-envelope. Projection metadata is explicit so import/export behavior remains stable and testable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactKind",
    "rulesVersion",
    "sourceRecordId",
    "sourceArtifactKind",
    "targetArtifactKind",
    "sourceLifecycleState",
    "deterministicSortKey",
    "projectedEnvelope"
  ],
  "properties": {
    "artifactKind": {
      "const": "governed-memory-record-projection"
    },
    "rulesVersion": {
      "const": "1.0.0"
    },
    "sourceRecordId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "sourceArtifactKind": {
      "const": "governed-memory-record"
    },
    "targetArtifactKind": {
      "const": "summary-only-session-context-envelope"
    },
    "sourceLifecycleState": {
      "type": "string",
      "enum": ["active", "superseded", "tombstoned"]
    },
    "deterministicSortKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "projectedEnvelope": {
      "$ref": "summary-only-session-context-envelope.schema.json"
    }
  }
}