{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/memory-export-result.schema.json",
  "title": "MemoryExportResult",
  "description": "Export result with output destination metadata. When --output is provided, the JSON envelope contains outputPath, memoryCount, and scope. When writing to stdout directly, the envelope contains exportedAt, dbPath, scope, and an array of memories.",
  "type": "object",
  "additionalProperties": false,
  "oneOf": [
    {
      "description": "Output when --output path is specified (writes memories to file, returns metadata).",
      "required": ["outputPath", "memoryCount", "scope"],
      "properties": {
        "outputPath": { "type": "string", "minLength": 1 },
        "memoryCount": { "type": "integer", "minimum": 0 },
        "scope": { "type": "string" }
      }
    },
    {
      "description": "Output when --output is omitted (memories written directly to stdout).",
      "required": ["exportedAt", "dbPath", "scope", "memories"],
      "properties": {
        "exportedAt": { "type": "string", "format": "date-time" },
        "dbPath": { "type": "string" },
        "scope": { "type": "string" },
        "memories": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "content", "scope", "memoryType", "provenance", "importanceScore", "reliabilityScore", "sensitivity", "state", "accessCount", "corroborationCount", "embeddingStale", "createdAt", "updatedAt"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "content": { "type": "string" },
              "summary": { "type": ["string", "null"] },
              "scope": { "type": "string" },
              "memoryType": { "type": "string" },
              "provenance": { "type": "string" },
              "importanceScore": { "type": "number" },
              "reliabilityScore": { "type": "number" },
              "sensitivity": { "type": "string" },
              "state": { "type": "string" },
              "tags": { "type": "array", "items": { "type": "string" } },
              "status": { "type": ["string", "null"] },
              "customMetadata": { "type": "object" },
              "accessCount": { "type": "integer", "minimum": 0 },
              "corroborationCount": { "type": "integer", "minimum": 0 },
              "embeddingStale": { "type": "boolean" },
              "createdAt": { "type": "string", "format": "date-time" },
              "updatedAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    }
  ]
}
