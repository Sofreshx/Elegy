{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/schemas/observation-summary.schema.json",
  "title": "ObservationSummary",
  "description": "Bounded observation summary for agent-friendly desktop activity handoff with progressive disclosure and token-aware hints.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scope",
    "representation",
    "summary",
    "observationCount",
    "observationKinds",
    "rawEventsPersisted"
  ],
  "properties": {
    "scope": {
      "type": "string",
      "enum": ["run", "session", "workspace"]
    },
    "representation": {
      "type": "string",
      "enum": ["observation-summary"]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "observationCount": {
      "type": "integer",
      "minimum": 0
    },
    "observationKinds": {
      "type": "object",
      "maxProperties": 16,
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "salientEvents": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "summary"],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 280
          },
          "count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "timeRange": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["startedAtUtc", "endedAtUtc"],
      "properties": {
        "startedAtUtc": {
          "type": "string",
          "format": "date-time"
        },
        "endedAtUtc": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "tokenEstimate": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "summaryChars": {
          "type": "integer",
          "minimum": 0
        },
        "salientEventChars": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rawEventsPersisted": {
      "const": false
    }
  }
}
