{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/canonical-workflow-graph.schema.json",
  "title": "CanonicalWorkflowGraph",
  "description": "Deterministic canonical workflow graph contract consumed by downstream engines and tooling.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "canonicalFormat",
    "canonicalVersion",
    "nodes",
    "edges",
    "variables"
  ],
  "properties": {
    "canonicalFormat": {
      "const": "canonical-workflow-graph"
    },
    "canonicalVersion": {
      "const": 1
    },
    "trigger": {
      "$ref": "#/$defs/trigger"
    },
    "entryStepId": {
      "type": [
        "string",
        "null"
      ]
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "variables": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/workflowVariable"
      }
    }
  },
  "$defs": {
    "jsonValue": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "workflowVariable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "dataType",
        "isSecret"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "dataType": {
          "type": "string",
          "minLength": 1
        },
        "defaultValue": {
          "$ref": "#/$defs/jsonValue"
        },
        "isSecret": {
          "type": "boolean"
        }
      }
    },
    "portDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "dataType",
        "required",
        "allowMultiple"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "typeDescriptor": {
          "$ref": "#/$defs/jsonValue"
        },
        "dataType": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "defaultValue": {
          "$ref": "#/$defs/jsonValue"
        },
        "allowMultiple": {
          "type": "boolean"
        },
        "schema": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "inputSchema"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "cronExpression": {
          "type": [
            "string",
            "null"
          ]
        },
        "timezone": {
          "type": [
            "string",
            "null"
          ]
        },
        "eventType": {
          "type": [
            "string",
            "null"
          ]
        },
        "inputSchema": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/portDefinition"
          }
        }
      }
    },
    "inputResolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceExpression": {
          "type": [
            "string",
            "null"
          ]
        },
        "staticValue": {
          "$ref": "#/$defs/jsonValue"
        },
        "transform": {
          "$ref": "#/$defs/connectionTransform"
        },
        "defaultValue": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    },
    "retryConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxRetries",
        "initialDelay",
        "maxDelay",
        "backoffMultiplier"
      ],
      "properties": {
        "maxRetries": {
          "type": "integer",
          "minimum": 0
        },
        "initialDelay": {
          "type": "string",
          "minLength": 1
        },
        "maxDelay": {
          "type": "string",
          "minLength": 1
        },
        "backoffMultiplier": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "retryableErrorCodes": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "scheduleConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "delaySeconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "executeAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "cronExpression": {
          "type": [
            "string",
            "null"
          ]
        },
        "intervalValue": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "intervalUnit": {
          "type": [
            "string",
            "null"
          ]
        },
        "startAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "endAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "maxOccurrences": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "humanReviewConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approverUserIds",
        "approverRoles",
        "sendNotification"
      ],
      "properties": {
        "approverUserIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "approverRoles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "instructions": {
          "type": [
            "string",
            "null"
          ]
        },
        "timeoutHours": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "sendNotification": {
          "type": "boolean"
        }
      }
    },
    "connectionTransform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "template": {
          "type": [
            "string",
            "null"
          ]
        },
        "lookupTable": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "string"
          }
        },
        "targetType": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "type",
        "inputs",
        "outputs",
        "config",
        "inputMappings",
        "inputResolutions",
        "onFailure",
        "maxRetries",
        "retryDelaySeconds",
        "timeoutSeconds",
        "persistOutput",
        "isEnabled"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "pieceId": {
          "type": [
            "string",
            "null"
          ]
        },
        "pieceType": {
          "type": [
            "string",
            "null"
          ]
        },
        "toolId": {
          "type": [
            "string",
            "null"
          ]
        },
        "addonVersion": {
          "type": [
            "integer",
            "null"
          ]
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/portDefinition"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/portDefinition"
          }
        },
        "config": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        "inputMappings": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "inputResolutions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/inputResolution"
          }
        },
        "onFailure": {
          "type": "string",
          "minLength": 1
        },
        "maxRetries": {
          "type": "integer",
          "minimum": 0
        },
        "retryDelaySeconds": {
          "type": "integer",
          "minimum": 0
        },
        "retryConfig": {
          "$ref": "#/$defs/retryConfig"
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "condition": {
          "type": [
            "string",
            "null"
          ]
        },
        "rollbackToolId": {
          "type": [
            "string",
            "null"
          ]
        },
        "schedule": {
          "$ref": "#/$defs/scheduleConfig"
        },
        "humanReview": {
          "$ref": "#/$defs/humanReviewConfig"
        },
        "persistOutput": {
          "type": "boolean"
        },
        "isEnabled": {
          "type": "boolean"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fromStepId",
        "fromPort",
        "toStepId",
        "toPort",
        "priority"
      ],
      "properties": {
        "fromStepId": {
          "type": "string",
          "minLength": 1
        },
        "fromPort": {
          "type": "string",
          "minLength": 1
        },
        "toStepId": {
          "type": "string",
          "minLength": 1
        },
        "toPort": {
          "type": "string",
          "minLength": 1
        },
        "transform": {
          "$ref": "#/$defs/connectionTransform"
        },
        "condition": {
          "type": [
            "string",
            "null"
          ]
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "priority": {
          "type": "integer"
        }
      }
    }
  }
}
