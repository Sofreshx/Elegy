{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/mcp-analysis-result.schema.json",
  "title": "MCP Analysis Result",
  "description": "Describes MCP tool analysis output before canonical skill projection.",
  "type": "object",
  "additionalProperties": false,
  "required": ["serverName", "analyses"],
  "properties": {
    "serverName": { "type": "string", "minLength": 1 },
    "analyses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool", "extractedTriggers", "hasValidSchema"],
        "properties": {
          "tool": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "description": { "type": ["string", "null"] },
              "inputSchema": { "type": ["object", "null"] }
            }
          },
          "extractedTriggers": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["pattern"],
              "properties": {
                "pattern": { "type": "string", "minLength": 1 },
                "description": { "type": ["string", "null"] }
              }
            }
          },
          "hasValidSchema": { "type": "boolean" }
        }
      }
    }
  }
}