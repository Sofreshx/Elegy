{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/skill-definition.schema.json",
  "title": "SkillDefinition",
  "description": "Canonical skill definition contract for non-.NET consumers.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "triggers", "constraints", "lifecycleState"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "definitionId": { "type": "string" },
        "displayName": { "type": "string" },
        "namespace": { "type": ["string", "null"] },
        "version": { "type": ["string", "null"] },
        "aliases": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": { "type": ["string", "null"] },
        "category": { "type": ["string", "null"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "owners": { "type": "array", "items": { "type": "string" } },
        "documentationUri": { "type": ["string", "null"] }
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pattern"],
        "properties": {
          "pattern": { "type": "string", "minLength": 1 },
          "description": { "type": ["string", "null"] }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["constraintId", "required"],
        "properties": {
          "constraintId": { "type": "string", "minLength": 1 },
          "description": { "type": ["string", "null"] },
          "required": { "type": "boolean" }
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type", "required"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "description": { "type": ["string", "null"] },
              "required": { "type": "boolean" }
            }
          }
        },
        "schemaRef": { "type": ["string", "null"] }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resultType": { "type": ["string", "null"] },
        "schemaRef": { "type": ["string", "null"] },
        "returnsCollection": { "type": "boolean" },
        "description": { "type": ["string", "null"] }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["requestResponse", "longRunning", "streaming"] },
        "isDeterministic": { "type": "boolean" },
        "hasSideEffects": { "type": "boolean" },
        "timeoutSeconds": { "type": ["integer", "null"], "minimum": 1 }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "approvalRequirement": { "type": "string", "enum": ["none", "advisory", "required"] },
        "policyRefs": { "type": "array", "items": { "type": "string" } },
        "allowedContexts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keywords": { "type": "array", "items": { "type": "string" } },
        "capabilityHints": { "type": "array", "items": { "type": "string" } },
        "isHidden": { "type": "boolean" }
      }
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "materializationKind": { "type": "string", "enum": ["declared", "dynamic"] },
        "sourceKind": { "type": "string", "enum": ["manual", "imported", "generated"] },
        "sourceRef": { "type": ["string", "null"] },
        "sourceVersion": { "type": ["string", "null"] }
      }
    },
    "lifecycleState": {
      "type": "string",
      "enum": ["draft", "active", "deprecated", "archived"]
    }
  }
}
