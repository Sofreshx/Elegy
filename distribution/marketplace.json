{
  "schemaVersion": "elegy-plugin-marketplace/v1",
  "name": "elegy-marketplace",
  "interface": {
    "displayName": "Elegy Plugin Marketplace"
  },
  "description": "Bundled plugin marketplace for the Elegy monorepo. Indexes shipped plugins by name and source. Authority for versions, capabilities, skills, executables, and interface metadata lives in each plugin's .elegy-plugin/plugin.json. Marketplace policy is installation metadata, never execution trust or approval.",
  "plugins": [
    {
      "name": "elegy-planning",
      "source": { "source": "local", "path": "plugins/planning" },
      "policy": { "installation": "AVAILABLE", "authentication": "NONE" },
      "category": "Productivity",
      "manifest": ".elegy-plugin/plugin.json"
    },
