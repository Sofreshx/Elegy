# Build outputs
**/[Bb]in/
!shared/plugin-sdk/src/bin/
!shared/plugin-sdk/src/bin/*.rs
**/[Oo]bj/
target/

# Test artifacts
TestResults/
*.trx
*.coverage
*.coveragexml

# Package/build artifacts
artifacts/
*.nupkg
*.snupkg

# Package managers
node_modules/
packages/

# IDE/editor
.vs/
.vscode/
.idea/
*.code-workspace
*.user
*.suo
*.userosscache
*.sln.docstates

# OS cruft
.DS_Store
Thumbs.db

# Local databases / agent state
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm
*.db-journal

# LLM temporary directories
.tmp/llm-input/
.tmp/llm-output/
.tmp/llm-work/

# Repo-local prompt/session scratch files
/prompt.md
/FLIGHT_RECORDER*.md
elegy-memory-mvp-test-plan.md
/action_shas.txt

# Local agent session artifacts
/target/agent-artifacts/

# elegy-memory-mcp local auth state
signing-key
clients.json
refresh-tokens.json

# Prevent accidental commit of extracted release payloads and malformed literal-path artifacts
/C*
/Users*AppData*Temp*
